# LLM-Ops-Kit runtime overrides (examples only; no secrets)
#
# Copy to .env.local (or export in shell) and adjust for your environment.

# Canonical repo root used by scripts for path resolution.
OPENCLAW_AGENT_WORK_ROOT=${HOME}/projects/LLM-Ops-Kit

# Toolkit-owned runtime state/log paths.
LLMOPS_HOME=${HOME}/.llmops
OPENCLAW_RUN_DIR=${LLMOPS_HOME}/run
OPENCLAW_LOG_DIR=${LLMOPS_HOME}/logs

# Upstream model endpoint defaults used by wrapper scripts.
OPENCLAW_UPSTREAM_HOST=<upstream-host>
OPENCLAW_UPSTREAM_PORT=<upstream-port>

# Proxy listen endpoint defaults.
OPENCLAW_PROXY_LISTEN_HOST=127.0.0.1
OPENCLAW_PROXY_LISTEN_PORT=<listen-port>

# Optional explicit proxy tap binary path.
# OPENCLAW_PROXY_TAP_BIN=~/projects/LLM-Ops-Kit/bin/openai-proxy-tap

# Sync defaults
SYNC_HOST=<sync-host>
SYNC_USER=<sync-user>
SYNC_REMOTE_DIR=${OPENCLAW_AGENT_WORK_ROOT}
SYNC_LOCAL_DIR=${OPENCLAW_AGENT_WORK_ROOT}
