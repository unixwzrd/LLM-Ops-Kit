# LLM-Ops-Kit runtime overrides (examples only; no secrets)
#
# Copy to .env.local (or export in shell) and adjust for your environment.

# Canonical repo root used by scripts for path resolution.
LLMOPS_AGENT_WORK_ROOT=${HOME}/projects/LLM-Ops-Kit

# Toolkit-owned runtime state/log paths.
LLMOPS_HOME=${HOME}/.llm-ops
LLMOPS_RUN_DIR=${LLMOPS_HOME}/run
LLMOPS_LOG_DIR=${LLMOPS_HOME}/logs

# Upstream model endpoint defaults used by wrapper scripts.
LLMOPS_UPSTREAM_HOST=<upstream-host>
LLMOPS_UPSTREAM_PORT=<upstream-port>

# Proxy listen endpoint defaults.
MODEL_PROXY_LISTEN_HOST=127.0.0.1
MODEL_PROXY_LISTEN_PORT=<listen-port>

# Optional explicit proxy tap binary path.
# MODEL_PROXY_TAP_BIN=~/projects/LLM-Ops-Kit/bin/model-proxy-tap

# Sync defaults
SYNC_HOST=<sync-host>
SYNC_USER=<sync-user>
SYNC_REMOTE_DIR=${LLMOPS_AGENT_WORK_ROOT}
SYNC_LOCAL_DIR=${LLMOPS_AGENT_WORK_ROOT}
