# LLM-Ops-Kit runtime overrides (examples only; no secrets)
#
# Copy to .env.local (or export in shell) and adjust for your environment.

# Toolkit-owned runtime state/log paths.
LLMOPS_HOME=${HOME}/.llm-ops
LLMOPS_RUN_DIR=${LLMOPS_HOME}/run
LLMOPS_LOG_DIR=${LLMOPS_HOME}/logs

# Upstream model endpoint defaults used by wrapper scripts.
# Required for remote model-proxy / sync workflows.
LLMOPS_UPSTREAM_HOST=<upstream-host>
LLMOPS_UPSTREAM_PORT=<upstream-port>
LLMOPS_SYNC_HOST=<sync-host>

# Proxy listen endpoint defaults.
MODEL_PROXY_LISTEN_HOST=127.0.0.1
MODEL_PROXY_LISTEN_PORT=<listen-port>

# Sync defaults
SYNC_USER=<sync-user>
SYNC_REMOTE_DIR=~/projects/LLM-Ops-Kit
SYNC_LOCAL_DIR=${HOME}/projects/LLM-Ops-Kit/

# TTS bridge defaults.
# Required when using local tts-bridge against a remote or separate MLX server.
TTS_BRIDGE_PORT=<listen-port>
TTS_BRIDGE_UPSTREAM_BASE=http://<upstream-host>:<port>/v1
TTS_BRIDGE_VOICE=<voice-name-for-customvoice>
TTS_BRIDGE_REF_AUDIO=/absolute/path/to/reference.wav
TTS_BRIDGE_REF_TEXT=/absolute/path/to/reference.txt

# Runtime retention.
LLMOPS_LOG_ROTATE_BYTES=10485760
LLMOPS_LOG_ROTATE_KEEP=5
LLMOPS_LOG_ROTATE_MAX_AGE_DAYS=14
LLMOPS_BACKUP_KEEP=5
LLMOPS_BACKUP_MAX_AGE_DAYS=30
