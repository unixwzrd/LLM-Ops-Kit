#!/usr/bin/env bash
set -euo pipefail

SOURCE="${BASH_SOURCE[0]}"
while [[ -h "$SOURCE" ]]; do
  DIR="$(cd -P "$(dirname "$SOURCE")" >/dev/null 2>&1 && pwd)"
  SOURCE="$(readlink "$SOURCE")"
  [[ "$SOURCE" != /* ]] && SOURCE="$DIR/$SOURCE"
done
SCRIPT_DIR="$(cd -P "$(dirname "$SOURCE")" >/dev/null 2>&1 && pwd)"
# shellcheck disable=SC1091
. "$SCRIPT_DIR/lib/common.sh"

is_action() {
  case "$1" in
    start|stop|restart|status|status-all|settings|verify|test|list) return 0 ;;
    *) return 1 ;;
  esac
}

normalize_action() {
  case "$1" in
    setttings|setings|settigns) echo "settings" ;;
    staus|statsu) echo "status" ;;
    restar|retsart) echo "restart" ;;
    verfy|veirfy) echo "verify" ;;
    *) echo "$1" ;;
  esac
}

resolve_model_from_invocation() {
  local bn
  bn="$(basename "$0")"
  if [[ "$bn" == "modelctl" ]]; then
    echo "Qwen3"
  else
    echo "$bn"
  fi
}

resolve_args() {
  local arg1
  local arg2
  local invoked_as
  arg1="$(normalize_action "${1:-}")"
  arg2="$(normalize_action "${2:-}")"
  invoked_as="$(basename "$0")"

  if [[ -z "$arg1" ]]; then
    model_name="$(resolve_model_from_invocation)"
    action="start"
    return
  fi

  if is_action "$arg1"; then
    if [[ "$invoked_as" == "modelctl" && ( "$arg1" == "status" || "$arg1" == "status-all" || "$arg1" == "list" ) ]]; then
      model_name="__all__"
      action="$arg1"
      return
    fi
    model_name="$(resolve_model_from_invocation)"
    action="$arg1"
    return
  fi

  model_name="$arg1"
  action="${arg2:-start}"
}

load_model_defaults() {
  local m="$1"
  local model_file="$SCRIPT_DIR/models/${m}.sh"
  [[ -f "$model_file" ]] || { echo "Model defaults not found: $model_file" >&2; exit 2; }

  # Precedence (highest -> lowest):
  # 1) external environment
  # 2) model profile
  # 3) model-kind defaults
  # 4) global llama.cpp defaults

  # 2) model profile
  # shellcheck disable=SC1091
  . "$model_file"

  # 3) model-type defaults
  case "${MODEL_TYPE:-}" in
    llm)
      # shellcheck disable=SC1091
      . "$SCRIPT_DIR/defaults/llm-defaults.sh"
      # shellcheck disable=SC1091
      . "$SCRIPT_DIR/defaults/llama-defaults.sh"
      ;;
    embedding)
      # shellcheck disable=SC1091
      . "$SCRIPT_DIR/defaults/embedding-defaults.sh"
      # shellcheck disable=SC1091
      . "$SCRIPT_DIR/defaults/llama-defaults.sh"
      ;;
    tts)
      # shellcheck disable=SC1091
      . "$SCRIPT_DIR/defaults/tts-defaults.sh"
      ;;
    *)
      echo "Unknown or missing MODEL_TYPE in $model_file: ${MODEL_TYPE:-<unset>}" >&2
      echo "Set MODEL_TYPE to llm, embedding, or tts in the model profile." >&2
      exit 2
      ;;
  esac
}

require_non_empty() {
  local name="$1"
  local value="${!name-}"
  if [[ -z "$value" ]]; then
    echo "Missing required setting: $name" >&2
    exit 2
  fi
}

validate_model_settings() {
  local common_runtime=(MODEL_PROFILE MODEL MODEL_TYPE PORT HOST)
  local common_llama=(THREADS THREADS_BATCH CTX_SIZE GPU_LAYERS BATCH_SIZE UBATCH_SIZE)
  local v
  for v in "${common_runtime[@]}"; do
    require_non_empty "$v"
  done

  case "$MODEL_TYPE" in
    llm)
      for v in "${common_llama[@]}"; do
        require_non_empty "$v"
      done
      if [[ "${USE_CUSTOM_TEMPLATE:-0}" == "1" ]]; then
        require_non_empty CHAT_TEMPLATE
        if [[ ! -f "$CHAT_TEMPLATE" ]]; then
          echo "Configured CHAT_TEMPLATE does not exist: $CHAT_TEMPLATE" >&2
          exit 2
        fi
      fi
      ;;
    embedding)
      for v in "${common_llama[@]}"; do
        require_non_empty "$v"
      done
      require_non_empty POOLING
      ;;
    tts)
      require_non_empty TTS_PYTHON_BIN
      require_non_empty TTS_SERVER_MODULE
      ;;
  esac
}

print_model_settings() {
  echo "modelctl settings ($model_name)"
  echo "  RUNTIME_MODE=$(runtime_mode)"
  echo "  RUNTIME_ROOT=$(runtime_asset_root)"
  echo "  MODEL_PROFILE=$MODEL_PROFILE"
  echo "  MODEL_TYPE=$MODEL_TYPE"
  echo "  MODEL=$MODEL"
  [[ -n "${MMPROJ:-}" ]] && echo "  MMPROJ=$MMPROJ"
  echo "  PORT=$PORT"
  echo "  HOST=$HOST"
  if [[ "$MODEL_TYPE" == "llm" || "$MODEL_TYPE" == "embedding" ]]; then
    echo "  THREADS=$THREADS"
    echo "  THREADS_BATCH=$THREADS_BATCH"
    echo "  CTX_SIZE=$CTX_SIZE"
    echo "  GPU_LAYERS=$GPU_LAYERS"
    echo "  BATCH_SIZE=$BATCH_SIZE"
    echo "  UBATCH_SIZE=$UBATCH_SIZE"
    echo "  TEMP=${TEMP:-}"
    echo "  TOP_P=${TOP_P:-}"
    echo "  TOP_K=${TOP_K:-}"
    echo "  MIN_P=${MIN_P:-}"
    echo "  PRESENCE_PENALTY=${PRESENCE_PENALTY:-}"
    echo "  REPEAT_PENALTY=${REPEAT_PENALTY:-}"
    echo "  USE_NO_WEBUI=${USE_NO_WEBUI:-0}"
    echo "  USE_NO_MMAP=${USE_NO_MMAP:-0}"
    echo "  USE_MLOCK=${USE_MLOCK:-0}"
    echo "  DIRECT_IO=${DIRECT_IO:-0}"
    echo "  VERBOSE_PROMPT=${VERBOSE_PROMPT:-0}"
  fi
  if [[ "$MODEL_TYPE" == "embedding" ]]; then
    echo "  POOLING=${POOLING:-}"
    if [[ "${MODEL_PROFILE:-}" == "bge-small-en" && "${CTX_SIZE:-0}" -gt 512 ]]; then
      echo "  WARNING=bge-small-en effective context is 512; higher CTX_SIZE may be ignored by runtime"
    fi
  fi
  if [[ "$MODEL_TYPE" == "llm" ]]; then
    echo "  USE_CUSTOM_TEMPLATE=${USE_CUSTOM_TEMPLATE:-0}"
    if [[ "${USE_CUSTOM_TEMPLATE:-0}" == "1" ]]; then
      echo "  CHAT_TEMPLATE=${CHAT_TEMPLATE:-}"
    fi
  fi
  if [[ "$MODEL_TYPE" == "tts" ]]; then
    echo "  TTS_PYTHON_BIN=${TTS_PYTHON_BIN:-}"
    echo "  TTS_SERVER_MODULE=${TTS_SERVER_MODULE:-}"
    echo "  TTS_API_KEY=${TTS_API_KEY:+<set>}"
    echo "  TTS_SERVER_ARGS=${TTS_SERVER_ARGS:-}"
  fi
}

model_name=""
action=""
resolve_args "${1:-}" "${2:-}"

if ! is_action "$action"; then
  echo "Invalid action: $action" >&2
  echo "Usage: $(basename "$0") [start|stop|restart|status|status-all|settings|verify|test|list]" >&2
  echo "   or: modelctl <model-profile> [start|stop|restart|status|settings|verify|test]" >&2
  exit 2
fi

if [[ "$action" == "start" || "$action" == "restart" || "$action" == "status" || "$action" == "settings" || "$action" == "verify" || "$action" == "test" ]]; then
  load_shell_env
fi
ensure_runtime_dirs

list_profiles() {
  find "$SCRIPT_DIR/models" -maxdepth 1 -type f -name '*.sh' -print \
    | sed -e 's#^.*/##' -e 's#\.sh$##' \
    | sort
}

if [[ "$model_name" == "__all__" ]]; then
  case "$action" in
    list)
      while IFS= read -r profile; do
        [[ -n "$profile" ]] || continue
        model_file="$SCRIPT_DIR/models/$profile.sh"
        MODEL_TYPE=""
        # shellcheck disable=SC1090
        . "$model_file"
        echo "$profile|${MODEL_TYPE:-unknown}"
      done < <(list_profiles)
      exit 0
      ;;
    status|status-all)
      rc=0
      first=1
      while IFS= read -r profile; do
        [[ -n "$profile" ]] || continue
        if [[ "$first" -eq 0 ]]; then
          echo
        fi
        first=0
        "$SCRIPT_DIR/modelctl" "$profile" status || rc=1
      done < <(list_profiles)
      exit "$rc"
      ;;
  esac
fi

load_model_defaults "$model_name"

if [[ "$MODEL_TYPE" == "llm" || "$MODEL_TYPE" == "embedding" ]]; then
  THREADS_BATCH="${THREADS_BATCH:-$THREADS}"
fi
validate_model_settings
if [[ "$MODEL_TYPE" == "tts" ]]; then
  pid_name="tts-$MODEL_PROFILE"
  model_log_file="$LLMOPS_LOG_DIR/tts-server-$MODEL_PROFILE.log"
else
  pid_name="llama-$MODEL_PROFILE"
  model_log_file="$LLMOPS_LOG_DIR/llama-server-$MODEL_PROFILE.log"
fi
state_file="$LLMOPS_RUN_DIR/$pid_name.state"

write_model_state() {
  local pid="$1"
  cat > "$state_file" <<EOF
MODEL_PROFILE=$MODEL_PROFILE
MODEL_TYPE=$MODEL_TYPE
PID=$pid
HOST=$HOST
PORT=$PORT
LOG_FILE=$model_log_file
STARTED_AT=$(date -u +%Y-%m-%dT%H:%M:%SZ)
EOF
}

read_model_state() {
  [[ -f "$state_file" ]] || return 1
  # shellcheck disable=SC1090
  . "$state_file"
}

clear_model_state() {
  rm -f "$state_file"
}

pid_matches_expected_process() {
  local pid="$1"
  local cmd=""
  cmd="$(ps -o command= -p "$pid" 2>/dev/null || true)"
  [[ -n "$cmd" ]] || return 1

  case "$MODEL_TYPE" in
    llm|embedding)
      [[ "$cmd" == *"llama-server"* ]] || return 1
      [[ "$cmd" == *"--port $PORT"* ]] || return 1
      ;;
    tts)
      [[ "$cmd" == *"$TTS_SERVER_MODULE"* ]] || return 1
      [[ "$cmd" == *"--port $PORT"* ]] || return 1
      ;;
  esac
  return 0
}

status_probe() {
  local base
  base="$(server_base_url)"
  if curl -fsS --max-time 2 "$base/v1/models" >/dev/null 2>&1; then
    echo "  api_probe=ok endpoint=$base/v1/models"
  else
    echo "  api_probe=failed endpoint=$base/v1/models"
  fi
}

status_model() {
  if pid="$(read_pid "$pid_name" 2>/dev/null)"; then
    if is_pid_running "$pid"; then
      if ! pid_matches_expected_process "$pid"; then
        echo "$pid_name: pid mismatch pid=$pid log=$model_log_file"
        [[ -f "$state_file" ]] && echo "  state_file=$state_file"
        print_model_settings
        return 1
      fi
      echo "$pid_name: running pid=$pid log=$model_log_file"
      if read_model_state 2>/dev/null; then
        echo "  started_at=${STARTED_AT:-unknown}"
        echo "  state_file=$state_file"
      fi
      status_probe
      print_model_settings
      return 0
    fi
    echo "$pid_name: stale pid=$pid log=$model_log_file"
    [[ -f "$state_file" ]] && echo "  state_file=$state_file"
    print_model_settings
    return 1
  fi
  echo "$pid_name: stopped log=$model_log_file"
  [[ -f "$state_file" ]] && echo "  state_file=$state_file"
  print_model_settings
  return 1
}

start_model() {
  print_model_settings

  if status_model >/dev/null 2>&1; then
    echo "$pid_name: already running"
    return 0
  fi

  if [[ "$MODEL_TYPE" == "llm" || "$MODEL_TYPE" == "embedding" ]]; then
    [[ -f "$MODEL" ]] || { echo "Model not found: $MODEL" >&2; exit 1; }
  else
    [[ -e "$MODEL" ]] || { echo "TTS model path not found: $MODEL" >&2; exit 1; }
  fi

  LOG_FILE="$model_log_file"
  prune_runtime_artifacts
  prepare_log_file "$LOG_FILE"
  EXTRA_ARGS=()
  MM_FLAGS=()
  TEMPLATE_FLAGS=()
  MODE_FLAGS=()
  DEBUG_FLAGS=()
  RUNTIME_FLAGS=()
  SAMPLING_FLAGS=()

  if [[ "$MODEL_TYPE" == "llm" ]]; then
    if [[ -n "${MMPROJ:-}" && -f "$MMPROJ" ]]; then
      MM_FLAGS+=(--mmproj "$MMPROJ")
    fi
    if [[ "${USE_CUSTOM_TEMPLATE:-0}" == "1" ]]; then
      [[ -f "$CHAT_TEMPLATE" ]] || { echo "Template not found: $CHAT_TEMPLATE" >&2; exit 1; }
      TEMPLATE_FLAGS+=(--jinja --chat-template-file "$CHAT_TEMPLATE")
    fi
    if [[ "${VERBOSE_PROMPT:-0}" == "1" ]]; then
      DEBUG_FLAGS+=(--verbose-prompt)
    fi
    if [[ "${USE_MLOCK:-0}" == "1" ]]; then
      RUNTIME_FLAGS+=(--mlock)
    fi
    if [[ "${USE_NO_MMAP:-0}" == "1" ]]; then
      RUNTIME_FLAGS+=(--no-mmap)
    fi
    if [[ "${USE_NO_WEBUI:-1}" == "1" ]]; then
      RUNTIME_FLAGS+=(--no-webui)
    fi
    if [[ "${DIRECT_IO:-0}" == "1" ]]; then
      if /usr/local/bin/llama-server --help 2>&1 | rg -q -- '--direct-io'; then
        RUNTIME_FLAGS+=(--direct-io)
      else
        echo "WARNING: DIRECT_IO=1 but llama-server does not support --direct-io; skipping."
      fi
    fi

    [[ -n "${TEMP:-}" ]] && SAMPLING_FLAGS+=(--temp "$TEMP")
    [[ -n "${TOP_P:-}" ]] && SAMPLING_FLAGS+=(--top-p "$TOP_P")
    [[ -n "${TOP_K:-}" ]] && SAMPLING_FLAGS+=(--top-k "$TOP_K")
    [[ -n "${MIN_P:-}" ]] && SAMPLING_FLAGS+=(--min-p "$MIN_P")
    [[ -n "${PRESENCE_PENALTY:-}" ]] && SAMPLING_FLAGS+=(--presence-penalty "$PRESENCE_PENALTY")
    [[ -n "${REPEAT_PENALTY:-}" ]] && SAMPLING_FLAGS+=(--repeat-penalty "$REPEAT_PENALTY")
  elif [[ "$MODEL_TYPE" == "embedding" ]]; then
    MODE_FLAGS+=(--embedding --pooling "$POOLING" --mmap)
    if [[ "${USE_NO_WEBUI:-1}" == "1" ]]; then
      RUNTIME_FLAGS+=(--no-webui)
    fi
    if [[ "${DIRECT_IO:-0}" == "1" ]]; then
      if /usr/local/bin/llama-server --help 2>&1 | rg -q -- '--direct-io'; then
        RUNTIME_FLAGS+=(--direct-io)
      else
        echo "WARNING: DIRECT_IO=1 but llama-server does not support --direct-io; skipping."
      fi
    fi
  elif [[ "$MODEL_TYPE" == "tts" ]]; then
    tts_cmd=( "$TTS_PYTHON_BIN" -m "$TTS_SERVER_MODULE" --host "$HOST" --port "$PORT" )
    if [[ -n "${TTS_API_KEY:-}" ]]; then
      tts_cmd+=( --api-key "$TTS_API_KEY" )
    fi
    if [[ -n "${TTS_SERVER_ARGS:-}" ]]; then
      # shellcheck disable=SC2206
      extra=( $TTS_SERVER_ARGS )
      tts_cmd+=( "${extra[@]}" )
    fi
    nohup "${tts_cmd[@]}" > "$LOG_FILE" 2>&1 &
  fi

  if [[ "$MODEL_TYPE" == "llm" || "$MODEL_TYPE" == "embedding" ]]; then
    nohup /usr/local/bin/llama-server \
      --model "$MODEL" \
      "${MM_FLAGS[@]}" \
      --ctx-size "$CTX_SIZE" \
      --gpu-layers "$GPU_LAYERS" \
      --batch-size "$BATCH_SIZE" \
      --ubatch-size "$UBATCH_SIZE" \
      --port "$PORT" \
      --host "$HOST" \
      --threads "$THREADS" \
      --threads-batch "$THREADS_BATCH" \
      "${SAMPLING_FLAGS[@]}" \
      "${RUNTIME_FLAGS[@]}" \
      "${TEMPLATE_FLAGS[@]}" \
      "${DEBUG_FLAGS[@]}" \
      --log-timestamps \
      --log-file "$LOG_FILE" \
      "${MODE_FLAGS[@]}" \
      "${EXTRA_ARGS[@]}" \
      > "$LOG_FILE" 2>&1 &
  fi

  pid="$!"
  write_pid "$pid_name" "$pid"
  write_model_state "$pid"
  echo "Started $pid_name pid=$pid log=$LOG_FILE"
}

stop_model() {
  if pid="$(read_pid "$pid_name" 2>/dev/null)"; then
    if is_pid_running "$pid" && ! pid_matches_expected_process "$pid"; then
      echo "$pid_name: pid mismatch pid=$pid, refusing to kill unexpected process" >&2
      rm -f "$(pid_file_for "$pid_name")"
      clear_model_state
      return 1
    fi
  fi
  stop_by_name "$pid_name"
  clear_model_state
}

server_base_url() {
  local h="$HOST"
  if [[ "$h" == "0.0.0.0" || "$h" == "::" ]]; then
    h="127.0.0.1"
  fi
  printf 'http://%s:%s\n' "$h" "$PORT"
}

REPORTED_MODEL_IDS=""
REPORTED_PRIMARY_MODEL=""

extract_model_ids() {
  local body="$1"
  if command -v jq >/dev/null 2>&1; then
    printf '%s' "$body" | jq -r '.data[]?.id' 2>/dev/null | paste -sd',' - || true
  else
    printf '%s' "$body" | sed -n 's/.*"id":"\([^"]*\)".*/\1/p' | paste -sd',' - || true
  fi
}

extract_primary_model_id() {
  local body="$1"
  if command -v jq >/dev/null 2>&1; then
    printf '%s' "$body" | jq -r '.data[0]?.id // empty' 2>/dev/null || true
  else
    printf '%s' "$body" | sed -n 's/.*"id":"\([^"]*\)".*/\1/p' | head -n 1 || true
  fi
}

verify_model() {
  local base body ids
  base="$(server_base_url)"
  echo "verify: profile=$MODEL_PROFILE type=$MODEL_TYPE endpoint=$base"
  if ! status_model >/dev/null 2>&1; then
    echo "verify: process not running" >&2
    return 1
  fi
  body="$(curl -fsS --max-time 20 "$base/v1/models" 2>/dev/null || true)"
  if [[ -z "$body" ]]; then
    echo "verify: failed to query $base/v1/models" >&2
    return 1
  fi
  ids="$(extract_model_ids "$body")"
  REPORTED_MODEL_IDS="$ids"
  REPORTED_PRIMARY_MODEL="$(extract_primary_model_id "$body")"
  if [[ -n "$ids" ]]; then
    echo "verify: reported_models=$ids"
  else
    echo "verify: reported_models=<unparsed>"
  fi
  if [[ -n "$REPORTED_PRIMARY_MODEL" ]]; then
    echo "verify: primary_model=$REPORTED_PRIMARY_MODEL"
  fi
  return 0
}

test_model() {
  local base payload out tmp_wav bytes request_model
  base="$(server_base_url)"
  verify_model
  request_model="${REPORTED_PRIMARY_MODEL:-$MODEL}"
  case "$MODEL_TYPE" in
    llm)
      payload="$(cat <<JSON
{"model":"$request_model","messages":[{"role":"user","content":"Reply with exactly: ALIVE"}],"max_tokens":16,"temperature":0}
JSON
)"
      out="$(curl -fsS --max-time 60 "$base/v1/chat/completions" -H 'Content-Type: application/json' -d "$payload")" || {
        echo "test: llm request failed" >&2
        return 1
      }
      if command -v jq >/dev/null 2>&1; then
        printf '%s\n' "$out" | jq -r '"test: llm_model=" + ("'"$request_model"'") + " llm_reply=" + (.choices[0].message.content // "<empty>")' 2>/dev/null || true
      else
        echo "test: llm request completed (model=$request_model)"
      fi
      ;;
    embedding)
      payload="$(cat <<JSON
{"model":"$request_model","input":"embedding heartbeat test"}
JSON
)"
      out="$(curl -fsS --max-time 60 "$base/v1/embeddings" -H 'Content-Type: application/json' -d "$payload")" || {
        echo "test: embedding request failed" >&2
        return 1
      }
      if command -v jq >/dev/null 2>&1; then
        printf '%s\n' "$out" | jq -r '"test: embedding_model=" + ("'"$request_model"'") + " embedding_vector_length=" + ((.data[0].embedding | length | tostring) // "0")' 2>/dev/null || true
      else
        echo "test: embedding request completed (model=$request_model)"
      fi
      ;;
    tts)
      tmp_wav="$(mktemp /tmp/qwen3tts-test-XXXXXX.wav)"
      payload="$(cat <<JSON
{"model":"$request_model","input":"Hey, I am alive.","response_format":"wav"}
JSON
)"
      curl -fsS --max-time 90 "$base/v1/audio/speech" -H 'Content-Type: application/json' -d "$payload" --output "$tmp_wav" || {
        rm -f "$tmp_wav"
        echo "test: tts request failed" >&2
        return 1
      }
      bytes="$(wc -c < "$tmp_wav" | tr -d '[:space:]')"
      echo "test: tts_model=$request_model tts_wav_path=$tmp_wav bytes=$bytes"
      if [[ "${bytes:-0}" -lt 128 ]]; then
        echo "test: tts output too small" >&2
        return 1
      fi
      ;;
  esac
}

case "$action" in
  start) start_model ;;
  stop) stop_model ;;
  restart) stop_model || true; start_model ;;
  status) status_model ;;
  settings) print_model_settings ;;
  verify) verify_model ;;
  test) test_model ;;
esac
