#!/usr/bin/env bash
# Host/IP defaults for local and remote ops wrappers.
# Override with exported env vars or CLI flags when needed.

# Primary model/upstream host used by proxy/sync defaults.
export OPENCLAW_UPSTREAM_HOST="${OPENCLAW_UPSTREAM_HOST:-10.0.0.67}"

# Optional dedicated sync host (falls back to OPENCLAW_UPSTREAM_HOST if unset).
export OPENCLAW_SYNC_HOST="${OPENCLAW_SYNC_HOST:-$OPENCLAW_UPSTREAM_HOST}"

