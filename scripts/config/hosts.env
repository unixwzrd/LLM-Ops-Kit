#!/usr/bin/env bash
# Host/IP defaults for local and remote ops wrappers.
# Override with exported env vars or CLI flags when needed.

# Primary model/upstream host used by proxy/sync wrappers.
# Intentionally unset by default; provide it from ~/.llm-ops/config.env,
# exported environment, or explicit CLI flags.
export LLMOPS_UPSTREAM_HOST="${LLMOPS_UPSTREAM_HOST:-}"

# Optional dedicated sync host (falls back to LLMOPS_UPSTREAM_HOST if unset).
export LLMOPS_SYNC_HOST="${LLMOPS_SYNC_HOST:-$LLMOPS_UPSTREAM_HOST}"
