#!/usr/bin/env bash
set -euo pipefail

SOURCE="${BASH_SOURCE[0]}"
while [[ -h "$SOURCE" ]]; do
  DIR="$(cd -P "$(dirname "$SOURCE")" >/dev/null 2>&1 && pwd)"
  SOURCE="$(readlink "$SOURCE")"
  [[ "$SOURCE" != /* ]] && SOURCE="$DIR/$SOURCE"
done
SCRIPT_DIR="$(cd -P "$(dirname "$SOURCE")" >/dev/null 2>&1 && pwd)"
# shellcheck disable=SC1091
. "$SCRIPT_DIR/lib/common.sh"

ACTION="${1:-status}"
shift || true

load_shell_env

LISTEN_HOST="${TTS_BRIDGE_HOST:-127.0.0.1}"
LISTEN_PORT="${TTS_BRIDGE_PORT:-11440}"
UPSTREAM_BASE="${TTS_BRIDGE_UPSTREAM_BASE:-}"
MODEL_PATH="${TTS_BRIDGE_MODEL:-$HOME/LLM_Repository/TTS/Qwen3-TTS-12Hz-0.6B-CustomVoice-8bit}"
CONFIG_DIR="${TTS_BRIDGE_CONFIG_DIR:-$HOME/.llm-ops}"
PRONOUNCE_CONFIG="${TTS_BRIDGE_PRONOUNCE_CONFIG:-}"
VOICE_MAP_CONFIG="${TTS_BRIDGE_VOICE_MAP_CONFIG:-}"
SAMPLES_DIR="${TTS_BRIDGE_SAMPLES_DIR:-$HOME/LLM_Repository/TTS/Samples}"
LOG_ROTATE_SECONDS="${TTS_BRIDGE_LOG_ROTATE_SECONDS:-86400}"
LOG_ROTATE_KEEP="${TTS_BRIDGE_LOG_ROTATE_KEEP:-5}"
REF_AUDIO="${TTS_BRIDGE_REF_AUDIO:-}"
REF_TEXT="${TTS_BRIDGE_REF_TEXT:-}"
if [[ -z "$REF_TEXT" && -n "$REF_AUDIO" ]]; then
  REF_TEXT="${REF_AUDIO%.*}.txt"
fi
PY_BIN="${TTS_BRIDGE_PYTHON_BIN:-python}"

pid_name="tts-bridge"
log_file="$LLMOPS_LOG_DIR/tts-bridge.log"

usage() {
  cat <<EOF
Usage: tts-bridge [start|stop|restart|status] [-- <extra python args>]

Env overrides:
  TTS_BRIDGE_HOST             (default: 127.0.0.1)
  TTS_BRIDGE_PORT             (default: 11440)
  TTS_BRIDGE_UPSTREAM_BASE    (required from ~/.llm-ops/config.env or explicit env)
  TTS_BRIDGE_MODEL            (default: Qwen3-TTS local path)
  TTS_BRIDGE_VOICE            (ignored by wrapper; bridge code selects/normalizes the effective voice)
  TTS_BRIDGE_PREFER_INCOMING_VOICE (default: 0; set 1 to honor incoming voice)
  TTS_BRIDGE_CONFIG_DIR       (default: ~/.llm-ops)
  TTS_BRIDGE_PRONOUNCE_CONFIG (optional; defaults to <config-dir>/pronounce.json)
  TTS_BRIDGE_VOICE_MAP_CONFIG (optional; defaults to <config-dir>/voice-map.json)
  TTS_BRIDGE_SAMPLES_DIR      (default: ~/LLM_Repository/TTS/Samples)
  TTS_BRIDGE_LOG_PATH         (default: ~/.llm-ops/logs/tts-bridge.log)
  TTS_BRIDGE_LOG_ROTATE_SECONDS (default: 86400)
  TTS_BRIDGE_LOG_ROTATE_KEEP  (default: 5)
  TTS_BRIDGE_REF_AUDIO        (optional bridge-level fallback)
  TTS_BRIDGE_REF_TEXT         (optional bridge-level fallback; derived from REF_AUDIO if set)
  TTS_BRIDGE_PYTHON_BIN       (default: python)
EOF
}

http_probe() {
  local url="$1"
  local detail_file status body code
  detail_file="/tmp/tts_bridge_probe_$$.txt"
  body="/tmp/tts_bridge_probe_body_$$.txt"
  code="$(curl -sS -o "$body" -w '%{http_code}' --max-time 3 "$url" 2>"$detail_file" || true)"
  if [[ "$code" =~ ^[0-9]{3}$ ]] && [[ "$code" != "000" ]]; then
    if [[ "$code" -ge 200 && "$code" -lt 400 ]]; then
      printf 'ok|http_status=%s\n' "$code"
    else
      printf 'down|http_status=%s\n' "$code"
    fi
  else
    status="$(cat "$detail_file" 2>/dev/null || true)"
    printf 'down|%s\n' "${status:-probe_failed}"
  fi
  rm -f "$detail_file" "$body" >/dev/null 2>&1 || true
}

bridge_health_json() {
  local url="$1"
  local body_file detail_file
  body_file="/tmp/tts_bridge_health_body_$$.json"
  detail_file="/tmp/tts_bridge_health_detail_$$.txt"
  if curl -sS --max-time 3 "$url" -o "$body_file" 2>"$detail_file"; then
    cat "$body_file"
  fi
  rm -f "$body_file" "$detail_file" >/dev/null 2>&1 || true
}

upstream_model_id() {
  local url="$1"
  local body_file detail_file
  body_file="/tmp/tts_bridge_models_body_$$.json"
  detail_file="/tmp/tts_bridge_models_detail_$$.txt"
  if curl -sS --max-time 3 "$url" -o "$body_file" 2>"$detail_file"; then
    if command -v jq >/dev/null 2>&1; then
      jq -r '
        if (.data | type) == "array" and (.data | length) > 0 then
          .data[0].id // ""
        else
          ""
        end
      ' "$body_file" 2>/dev/null || true
    fi
  fi
  rm -f "$body_file" "$detail_file" >/dev/null 2>&1 || true
}

upstream_models_url() {
  if [[ "$UPSTREAM_BASE" == */v1 ]]; then
    printf '%s/models\n' "$UPSTREAM_BASE"
  else
    printf '%s/v1/models\n' "$UPSTREAM_BASE"
  fi
}

listener_pid() {
  command -v lsof >/dev/null 2>&1 || return 1
  lsof -nP -t -iTCP:"$LISTEN_PORT" -sTCP:LISTEN 2>/dev/null | head -n 1
}

bridge_health_url() {
  printf 'http://%s:%s/health\n' "$LISTEN_HOST" "$LISTEN_PORT"
}

status_bridge() {
  local pid="" bridge_url upstream_url bridge_probe upstream_probe bridge_state="down" upstream_state="down"
  local bridge_detail="" upstream_detail="" port_pid="" reported_model="" bridge_payload=""
  local health_config_dir="" health_pronounce_config="" health_voice_map_config="" health_samples_dir=""
  local health_ref_audio="" health_ref_text="" health_voice=""
  bridge_url="$(bridge_health_url)"
  upstream_url="$(upstream_models_url)"

  if pid="$(read_pid "$pid_name" 2>/dev/null)"; then
    if is_pid_running "$pid"; then
      echo "$pid_name: running pid=$pid"
    else
      echo "$pid_name: stale pid=$pid"
    fi
  else
    echo "$pid_name: stopped"
  fi

  port_pid="$(listener_pid || true)"
  if [[ -n "$port_pid" ]]; then
    echo "  listener_pid=$port_pid"
  else
    echo "  listener_pid=<none>"
  fi

  bridge_probe="$(http_probe "$bridge_url")"
  bridge_state="${bridge_probe%%|*}"
  bridge_detail="${bridge_probe#*|}"
  if [[ "$bridge_state" == "ok" ]]; then
    bridge_payload="$(bridge_health_json "$bridge_url" || true)"
    if [[ -n "$bridge_payload" ]] && command -v jq >/dev/null 2>&1; then
      health_config_dir="$(printf '%s' "$bridge_payload" | jq -r '.config.config_dir // ""' 2>/dev/null || true)"
      health_pronounce_config="$(printf '%s' "$bridge_payload" | jq -r '.config.pronounce_config // ""' 2>/dev/null || true)"
      health_voice_map_config="$(printf '%s' "$bridge_payload" | jq -r '.config.voice_map_config // ""' 2>/dev/null || true)"
      health_samples_dir="$(printf '%s' "$bridge_payload" | jq -r '.config.samples_dir // ""' 2>/dev/null || true)"
      health_ref_audio="$(printf '%s' "$bridge_payload" | jq -r '.defaults.ref_audio // ""' 2>/dev/null || true)"
      health_ref_text="$(printf '%s' "$bridge_payload" | jq -r '.defaults.ref_text // ""' 2>/dev/null || true)"
      health_voice="$(printf '%s' "$bridge_payload" | jq -r '.defaults.voice // ""' 2>/dev/null || true)"
    fi
  fi

  upstream_probe="$(http_probe "$upstream_url")"
  upstream_state="${upstream_probe%%|*}"
  upstream_detail="${upstream_probe#*|}"
  if [[ "$upstream_state" == "ok" ]]; then
    reported_model="$(upstream_model_id "$upstream_url" || true)"
  fi

  echo "  listen=$bridge_url"
  echo "  upstream=$UPSTREAM_BASE"
  echo "  upstream_models_endpoint=$upstream_url"
  if [[ -n "$reported_model" ]]; then
    echo "  model=$reported_model"
  else
    echo "  model=<upstream-unreported>"
  fi
  echo "  voice=${health_voice:-<bridge-selected>}"
  echo "  config_dir=${health_config_dir:-$CONFIG_DIR}"
  echo "  pronounce_config=${health_pronounce_config:-${PRONOUNCE_CONFIG:-<config-dir>/pronounce.json}}"
  echo "  voice_map_config=${health_voice_map_config:-${VOICE_MAP_CONFIG:-<config-dir>/voice-map.json}}"
  echo "  samples_dir=${health_samples_dir:-$SAMPLES_DIR}"
  echo "  ref_audio=${health_ref_audio:-$REF_AUDIO}"
  echo "  ref_text=${health_ref_text:-$REF_TEXT}"
  echo "  log=$log_file"
  echo "  log_rotate_seconds=$LOG_ROTATE_SECONDS"
  echo "  log_rotate_keep=$LOG_ROTATE_KEEP"
  echo "  runtime_mode=$(runtime_mode)"
  echo "  runtime_root=$(runtime_asset_root)"
  echo "  retention=$(retention_summary_line)"
  echo "  health=$bridge_state"
  echo "  health_detail=$bridge_detail"
  echo "  upstream_health=$upstream_state"
  echo "  upstream_health_detail=$upstream_detail"

  if [[ "$bridge_state" == "ok" && "$upstream_state" == "ok" ]]; then
    return 0
  fi
  return 1
}

start_bridge() {
  ensure_runtime_dirs
  prune_runtime_artifacts
  prepare_log_file "$log_file"

  if [[ -z "$UPSTREAM_BASE" ]]; then
    print_missing_config_hint \
      "tts-bridge: missing TTS_BRIDGE_UPSTREAM_BASE" \
      TTS_BRIDGE_UPSTREAM_BASE \
      TTS_BRIDGE_PORT
    return 2
  fi

  if status_bridge >/dev/null 2>&1; then
    echo "$pid_name: already running"
    return 0
  fi

  # MODEL_PATH/REF_AUDIO/REF_TEXT are forwarded to upstream MLX server and may
  # refer to paths that exist only on the upstream host.
  if [[ ! -e "$MODEL_PATH" ]]; then
    echo "tts-bridge: warning: model path not found locally (will still forward): $MODEL_PATH" >&2
  fi
  if [[ -n "$REF_AUDIO" && ! -f "$REF_AUDIO" ]]; then
    echo "tts-bridge: warning: ref audio not found locally (will still forward): $REF_AUDIO" >&2
  fi
  if [[ -n "$REF_TEXT" && ! -f "$REF_TEXT" ]]; then
    echo "tts-bridge: warning: ref text not found locally (will still forward): $REF_TEXT" >&2
  fi

  local -a cmd
  cmd=(
    "$PY_BIN" "$SCRIPT_DIR/tts_bridge_server.py"
    --listen-host "$LISTEN_HOST"
    --listen-port "$LISTEN_PORT"
    --upstream-base "$UPSTREAM_BASE"
    --model "$MODEL_PATH"
    --log-path "$log_file"
    --log-rotate-seconds "$LOG_ROTATE_SECONDS"
    --log-rotate-keep "$LOG_ROTATE_KEEP"
    --config-dir "$CONFIG_DIR"
    --samples-dir "$SAMPLES_DIR"
    --ref-audio "$REF_AUDIO"
    --ref-text "$REF_TEXT"
  )

  if [[ -n "$PRONOUNCE_CONFIG" ]]; then
    cmd+=(--pronounce-config "$PRONOUNCE_CONFIG")
  fi
  if [[ -n "$VOICE_MAP_CONFIG" ]]; then
    cmd+=(--voice-map-config "$VOICE_MAP_CONFIG")
  fi
  if [[ $# -gt 0 ]]; then
    cmd+=("$@")
  fi

  nohup "${cmd[@]}" \
    < /dev/null \
    > "$log_file" 2>&1 &

  write_pid "$pid_name" "$!"
  start_log_marktime "$pid_name" "$pid_name" "$log_file"
  echo "Started $pid_name pid=$! log=$log_file"
}

stop_bridge() {
  stop_by_name "$pid_name"
  stop_log_marktime "$pid_name"
}

case "$ACTION" in
  start) start_bridge "$@" ;;
  stop) stop_bridge ;;
  restart) stop_bridge || true; start_bridge "$@" ;;
  status) status_bridge ;;
  -h|--help|help) usage ;;
  *)
    echo "Invalid action: $ACTION" >&2
    usage >&2
    exit 2
    ;;
esac
