#!/usr/bin/env bash
set -euo pipefail

SOURCE="${BASH_SOURCE[0]}"
while [[ -h "$SOURCE" ]]; do
  DIR="$(cd -P "$(dirname "$SOURCE")" >/dev/null 2>&1 && pwd)"
  SOURCE="$(readlink "$SOURCE")"
  [[ "$SOURCE" != /* ]] && SOURCE="$DIR/$SOURCE"
done
SCRIPT_DIR="$(cd -P "$(dirname "$SOURCE")" >/dev/null 2>&1 && pwd)"
# shellcheck disable=SC1091
. "$SCRIPT_DIR/lib/common.sh"

action="${1:-status}"
LLMOPS_REQUIRED_SECRETS="${LLMOPS_REQUIRED_SECRETS:-}"
shift || true

PROXY_TAP_BIN="${MODEL_PROXY_TAP_BIN:-$LLMOPS_ROOT/bin/model-proxy-tap}"
MODEL_PROXY_LOG_ROTATE_SECONDS="${MODEL_PROXY_LOG_ROTATE_SECONDS:-86400}"
MODEL_PROXY_LOG_ROTATE_KEEP="${MODEL_PROXY_LOG_ROTATE_KEEP:-5}"
MODEL_PROXY_CHAT_TEMPLATE="${MODEL_PROXY_CHAT_TEMPLATE:-}"

# Accept GNU-style action aliases (e.g. `model-proxy --status`).
case "$action" in
  --status) action="status" ;;
  --start) action="start" ;;
  --stop) action="stop" ;;
  --restart) action="restart" ;;
  --help|-h) action="--help" ;;
esac

usage() {
  cat <<USAGE
Usage: model-proxy [start|stop|restart|status|render] [options]

Options:
  start/restart: all options are passed through directly to model-proxy-tap.
  stop: use --force for SIGKILL.
  render: pass -i/--input/--render-input <payload.json> to render prompt(s) without starting the proxy. Use '-' to read stdin.
  -h, --help: show this help.

Default env-backed values:
  LLMOPS_ROOT=${LLMOPS_ROOT}
  LLMOPS_UPSTREAM_HOST=<required from ~/.llm-ops/config.env or explicit env>
  LLMOPS_UPSTREAM_PORT=<required from ~/.llm-ops/config.env or explicit env>
  MODEL_PROXY_LISTEN_PORT=<optional; defaults to upstream port>
  MODEL_PROXY_LOG_ROTATE_SECONDS=<optional; defaults to 86400>
  MODEL_PROXY_LOG_ROTATE_KEEP=<optional; defaults to 5>
  MODEL_PROXY_CHAT_TEMPLATE=<optional default chat template path>

Examples:
  model-proxy restart --upstream http://<configured-upstream-host>:<configured-upstream-port>
  model-proxy restart --listen-port <listen-port> --upstream http://<configured-upstream-host>:<configured-upstream-port>
USAGE
}

if [[ "$action" == "-h" || "$action" == "--help" ]]; then
  usage
  exit 0
fi

extra_args=("$@")

has_upstream_arg() {
  local i arg
  for ((i = 0; i < ${#extra_args[@]}; i++)); do
    arg="${extra_args[$i]}"
    case "$arg" in
      --upstream|--upstream=*)
        return 0
        ;;
    esac
  done
  return 1
}

arg_value() {
  # Usage: arg_value --name [--alt-name]
  local want1="$1"
  local want2="${2:-}"
  local i arg next
  for ((i = 0; i < ${#extra_args[@]}; i++)); do
    arg="${extra_args[$i]}"
    next="${extra_args[$((i + 1))]:-}"
    case "$arg" in
      "$want1"|"$want2")
        printf '%s\n' "$next"
        return 0
        ;;
      "$want1"=*|"$want2"=*)
        printf '%s\n' "${arg#*=}"
        return 0
        ;;
    esac
  done
  return 1
}

runtime_file() {
  printf '%s/%s\n' "$LLMOPS_RUN_DIR" "$1"
}

read_runtime() {
  local name="$1"
  local f
  f="$(runtime_file "$name")"
  [[ -f "$f" ]] || return 1
  cat "$f"
}

write_runtime() {
  local name="$1"
  local value="$2"
  printf '%s\n' "$value" > "$(runtime_file "$name")"
}

clear_live_runtime() {
  rm -f \
    "$(runtime_file model-proxy-live-listen-host)" \
    "$(runtime_file model-proxy-live-listen-port)" \
    "$(runtime_file model-proxy-live-upstream)" \
    "$(runtime_file model-proxy-live-log)" \
    "$(runtime_file model-proxy-live-chat-template)" \
    "$(runtime_file model-proxy-live-raw-request-log)" \
    "$(runtime_file model-proxy-live-rendered-prompt-log)" \
    "$(runtime_file model-proxy-live-raw-response-log)"
}

extract_port_from_upstream() {
  # Accepts forms like:
  # - <upstream-host>:<upstream-port>
  # - http://<upstream-host>:<upstream-port>
  # - http://user:pass@<upstream-host>:<upstream-port>/v1
  # - http://[::1]:11434/v1
  local upstream="$1"
  [[ -n "$upstream" ]] || return 0

  local s hostport port=""
  s="${upstream#*://}"    # strip scheme if present
  hostport="${s%%/*}"     # strip path
  hostport="${hostport%%\?*}"
  hostport="${hostport%%#*}"
  hostport="${hostport##*@}" # strip userinfo if present

  if [[ "$hostport" =~ ^\[[^]]+\]:([0-9]+)$ ]]; then
    port="${BASH_REMATCH[1]}"
  elif [[ "$hostport" =~ :([0-9]+)$ ]]; then
    port="${BASH_REMATCH[1]}"
  fi

  if [[ "$port" =~ ^[0-9]+$ ]]; then
    printf '%s\n' "$port"
  fi
}

resolve_listen_port() {
  # Priority:
  # 1) explicit --listen-port/--port in CLI args
  # 2) persisted model-proxy-listen-port runtime file
  # 3) upstream port in --upstream
  local i arg next
  for ((i = 0; i < ${#extra_args[@]}; i++)); do
    arg="${extra_args[$i]}"
    next="${extra_args[$((i + 1))]:-}"
    case "$arg" in
      --listen-port|--port)
        if [[ "$next" =~ ^[0-9]+$ ]]; then
          printf '%s\n' "$next"
          return 0
        fi
        ;;
      --listen-port=*|--port=*)
        printf '%s\n' "${arg#*=}"
        return 0
        ;;
    esac
  done

  local persisted_port="$LLMOPS_RUN_DIR/model-proxy-listen-port"
  if [[ -f "$persisted_port" ]]; then
    local p
    p="$(tr -d '[:space:]' < "$persisted_port" || true)"
    if [[ "$p" =~ ^[0-9]+$ ]]; then
      printf '%s\n' "$p"
      return 0
    fi
  fi

  for ((i = 0; i < ${#extra_args[@]}; i++)); do
    arg="${extra_args[$i]}"
    next="${extra_args[$((i + 1))]:-}"
    case "$arg" in
      --upstream)
        if [[ -n "$next" ]]; then
          extract_port_from_upstream "$next"
          return 0
        fi
        ;;
      --upstream=*)
        extract_port_from_upstream "${arg#*=}"
        return 0
        ;;
    esac
  done
}

kill_port_listener() {
  local port="$1"
  [[ "$port" =~ ^[0-9]+$ ]] || return 0
  command -v lsof >/dev/null 2>&1 || return 0

  local pids
  pids="$(lsof -nP -t -iTCP:"$port" -sTCP:LISTEN 2>/dev/null | tr '\n' ' ' || true)"
  [[ -n "${pids// }" ]] || return 0

  echo "model-proxy: killing listener(s) on port $port: $pids"
  # shellcheck disable=SC2086
  kill $pids >/dev/null 2>&1 || true
  sleep 1
  pids="$(lsof -nP -t -iTCP:"$port" -sTCP:LISTEN 2>/dev/null | tr '\n' ' ' || true)"
  if [[ -n "${pids// }" ]]; then
    # shellcheck disable=SC2086
    kill -9 $pids >/dev/null 2>&1 || true
  fi
}

start_proxy() {
  load_shell_env
  ensure_runtime_dirs
  prune_runtime_artifacts

  local configured_upstream_host="${LLMOPS_UPSTREAM_HOST:-}"
  local configured_upstream_port="${LLMOPS_UPSTREAM_PORT:-}"

  if pid="$(read_pid model-proxy 2>/dev/null)" && is_pid_running "$pid"; then
    echo "model-proxy: already running pid=$pid"
    return 0
  fi

  LOG_OUT="$LLMOPS_LOG_DIR/model-proxy-tap.log"
  LOG_ERR="$LLMOPS_LOG_DIR/model-proxy-tap.err.log"
  prepare_log_file "$LOG_OUT"
  prepare_log_file "$LOG_ERR"

  if ! has_upstream_arg && [[ -z "$configured_upstream_host" || -z "$configured_upstream_port" ]]; then
    print_missing_config_hint \
      "model-proxy: missing upstream configuration" \
      LLMOPS_UPSTREAM_HOST \
      LLMOPS_UPSTREAM_PORT \
      MODEL_PROXY_LISTEN_PORT
    return 2
  fi

  if ! has_upstream_arg && [[ -n "$configured_upstream_host" && -n "$configured_upstream_port" ]]; then
    extra_args=(--upstream "http://${configured_upstream_host}:${configured_upstream_port}" "${extra_args[@]}")
  fi

  if [[ -n "$MODEL_PROXY_CHAT_TEMPLATE" ]] && ! arg_value --chat-template >/dev/null 2>&1; then
    extra_args=(--chat-template "$MODEL_PROXY_CHAT_TEMPLATE" "${extra_args[@]}")
  fi

  nohup "$PROXY_TAP_BIN" "${extra_args[@]}" > "$LOG_OUT" 2> "$LOG_ERR" &
  pid="$!"
  sleep 0.4
  if ! is_pid_running "$pid"; then
    echo "model-proxy: failed to start (pid exited). recent stderr:"
    tail -n 20 "$LOG_ERR" 2>/dev/null || true
    return 1
  fi
  write_pid model-proxy "$pid"
  # Persist effective live settings for status output.
  local listen_host listen_port upstream log tmpl raw_req rendered raw_resp
  listen_host="$(arg_value --listen-host 2>/dev/null || true)"
  listen_host="${listen_host:-127.0.0.1}"

  listen_port="$(arg_value --listen-port --port 2>/dev/null || true)"
  upstream="$(arg_value --upstream 2>/dev/null || true)"
  if [[ -z "$listen_port" && -n "$upstream" ]]; then
    listen_port="$(extract_port_from_upstream "$upstream" || true)"
  fi

  log="$(arg_value --log 2>/dev/null || true)"
  log="${log:-$LLMOPS_LOG_DIR/model-proxy.ndjson}"
  tmpl="$(arg_value --chat-template 2>/dev/null || true)"
  tmpl="${tmpl:-$MODEL_PROXY_CHAT_TEMPLATE}"
  raw_req="$(arg_value --raw-request-log 2>/dev/null || true)"
  raw_req="${raw_req:-$LLMOPS_LOG_DIR/model-proxy.raw.log}"
  rendered="$(arg_value --rendered-prompt-log 2>/dev/null || true)"
  rendered="${rendered:-$LLMOPS_LOG_DIR/model-proxy.rendered.log}"
  raw_resp="$(arg_value --raw-response-log 2>/dev/null || true)"
  raw_resp="${raw_resp:-$raw_req}"

  write_runtime model-proxy-live-listen-host "$listen_host"
  write_runtime model-proxy-live-listen-port "${listen_port:-}"
  write_runtime model-proxy-live-upstream "${upstream:-}"
  write_runtime model-proxy-live-log "$log"
  write_runtime model-proxy-live-chat-template "${tmpl:-}"
  write_runtime model-proxy-live-raw-request-log "$raw_req"
  write_runtime model-proxy-live-rendered-prompt-log "$rendered"
  write_runtime model-proxy-live-raw-response-log "${raw_resp:-}"

  echo "model-proxy: started pid=$pid"
}

stop_proxy() {
  local target_port
  target_port="$(resolve_listen_port || true)"
  if [[ " ${extra_args[*]} " == *" --force "* ]]; then
    pf="$(pid_file_for model-proxy)"
    if [[ -f "$pf" ]]; then
      pid="$(cat "$pf")"
      if is_pid_running "$pid"; then
        kill -9 "$pid" >/dev/null 2>&1 || true
        echo "model-proxy: force-stopped pid $pid"
      fi
      rm -f "$pf"
    else
      echo "model-proxy: no pid file"
    fi
  else
    stop_by_name model-proxy
  fi
  if [[ -n "${target_port:-}" ]]; then
    kill_port_listener "$target_port"
  fi
  clear_live_runtime
}

status_proxy() {
  local pid="" listen_host listen_port upstream log tmpl raw_req rendered raw_resp
  local health="unknown" health_detail="" listener_pid=""

  if pid="$(read_pid model-proxy 2>/dev/null)"; then
    if is_pid_running "$pid"; then
      echo "model-proxy: running pid=$pid"
    else
      echo "model-proxy: stale pid=$pid"
    fi
  else
    echo "model-proxy: stopped"
  fi

  listen_host="$(read_runtime model-proxy-live-listen-host 2>/dev/null || true)"
  listen_port="$(read_runtime model-proxy-live-listen-port 2>/dev/null || true)"
  upstream="$(read_runtime model-proxy-live-upstream 2>/dev/null || true)"
  log="$(read_runtime model-proxy-live-log 2>/dev/null || true)"
  tmpl="$(read_runtime model-proxy-live-chat-template 2>/dev/null || true)"
  raw_req="$(read_runtime model-proxy-live-raw-request-log 2>/dev/null || true)"
  rendered="$(read_runtime model-proxy-live-rendered-prompt-log 2>/dev/null || true)"
  raw_resp="$(read_runtime model-proxy-live-raw-response-log 2>/dev/null || true)"

  listen_host="${listen_host:-127.0.0.1}"
  log="${log:-$LLMOPS_LOG_DIR/model-proxy.ndjson}"
  raw_req="${raw_req:-$LLMOPS_LOG_DIR/model-proxy.raw.log}"
  rendered="${rendered:-$LLMOPS_LOG_DIR/model-proxy.rendered.log}"
  raw_resp="${raw_resp:-$raw_req}"

  if [[ -n "$listen_port" ]] && command -v lsof >/dev/null 2>&1; then
    listener_pid="$(lsof -nP -t -iTCP:"$listen_port" -sTCP:LISTEN 2>/dev/null | head -n 1 || true)"
  fi

  if [[ -n "$listen_port" ]]; then
    if command -v curl >/dev/null 2>&1; then
      local code
      code="$(curl -sS -o /dev/null -w "%{http_code}" --max-time 2 "http://${listen_host}:${listen_port}/v1/models" 2>/tmp/model_proxy_status_err.$$ || true)"
      if [[ "$code" =~ ^[0-9]{3}$ ]]; then
        if [[ "$code" -ge 200 && "$code" -lt 300 ]]; then
          health="ok"
        else
          health="down"
        fi
        health_detail="http_status=$code"
      else
        health="down"
        health_detail="$(cat /tmp/model_proxy_status_err.$$ 2>/dev/null || true)"
      fi
      rm -f /tmp/model_proxy_status_err.$$ >/dev/null 2>&1 || true
    else
      health="unknown"
      health_detail="curl not found"
    fi
  fi

  echo "  listen=http://${listen_host}:${listen_port:-<from-upstream/default>}"
  echo "  listener_pid=${listener_pid:-<none>}"
  echo "  upstream=${upstream:-<unset>}"
  echo "  log=$log"
  echo "  log_rotate_seconds=${MODEL_PROXY_LOG_ROTATE_SECONDS}"
  echo "  log_rotate_keep=${MODEL_PROXY_LOG_ROTATE_KEEP}"
  echo "  chat_template=${tmpl:-<none/default>}"
  echo "  raw_request_log=$raw_req"
  echo "  rendered_prompt_log=$rendered"
  echo "  raw_response_log=${raw_resp:-<off>}"
  echo "  runtime_mode=$(runtime_mode)"
  echo "  runtime_root=$(runtime_asset_root)"
  echo "  retention=$(retention_summary_line)"
  echo "  health=$health"
  if [[ -n "$health_detail" ]]; then
    echo "  health_detail=$health_detail"
  fi

  if [[ "$health" == "ok" ]]; then
    return 0
  fi
  return 1
}

render_proxy() {
  load_shell_env
  ensure_runtime_dirs

  local render_input=""
  render_input="$(arg_value -i --input 2>/dev/null || arg_value --render-input 2>/dev/null || true)"
  if [[ -z "$render_input" ]]; then
    echo "model-proxy: render requires -i/--input/--render-input <payload.json>"
    return 2
  fi

  local tmpl
  tmpl="$(arg_value --chat-template 2>/dev/null || true)"
  tmpl="${tmpl:-$MODEL_PROXY_CHAT_TEMPLATE}"
  if [[ -n "$tmpl" ]] && ! arg_value --chat-template >/dev/null 2>&1; then
    extra_args=(--chat-template "$tmpl" "${extra_args[@]}")
  fi

  local forwarded_args=()
  local i arg next
  for ((i = 0; i < ${#extra_args[@]}; i++)); do
    arg="${extra_args[$i]}"
    next="${extra_args[$((i + 1))]:-}"
    case "$arg" in
      -i|--input|--render-input)
        ((i++))
        ;;
      -i=*|--input=*|--render-input=*)
        ;;
      *)
        forwarded_args+=("$arg")
        ;;
    esac
  done

  "$PROXY_TAP_BIN" --render-input "$render_input" "${forwarded_args[@]}"
}

case "$action" in
  start) start_proxy ;;
  stop) stop_proxy ;;
  restart) stop_proxy || true; start_proxy ;;
  status) status_proxy ;;
  render) render_proxy ;;
  *)
    usage
    exit 2
    ;;
esac
