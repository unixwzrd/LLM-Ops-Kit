{{- bos_token -}}
{%- set TOOL_CONTENT_MAX = 12000 -%}
{%- set TOOL_HISTORY_LIMIT = 4 -%}
{%- set INCLUDE_TOOL_CALL_HISTORY = false -%}

{%- macro clean_user_text(t) -%}
    {%- if t is string and 'Conversation info (untrusted metadata):' in t -%}
        {%- set parts = t.split('\n\n') -%}
        {%- if parts|length >= 2 -%}
            {{ parts[-1] }}
        {%- else -%}
            {{ t }}
        {%- endif -%}
    {%- else -%}
        {{ t }}
    {%- endif -%}
{%- endmacro -%}

{%- macro render_content(c, role='') -%}
    {%- if c is string -%}
        {%- if role == 'assistant' and ('{"tool_calls"' in c or '<tool_call>' in c) -%}
            {# skip leaked raw tool-call text fragments #}
        {%- elif role == 'user' -%}
            {{ clean_user_text(c) }}
        {%- elif role == 'assistant' -%}
            {{ c | replace('<system>', '') | replace('</system>', '') }}
        {%- else -%}
            {{ c }}
        {%- endif -%}
    {%- elif c is mapping -%}
        {%- if c.type is defined and (c.type == 'thinking' or c.type == 'reasoning' or c.type == 'reasoning_content') -%}
            {# skip reasoning blocks from history #}
        {%- elif c.thinking is defined -%}
            {# skip reasoning blocks from history #}
        {%- elif c.type is defined and (c.type == 'text' or c.type == 'input_text') and c.text is defined -%}
            {%- if role == 'assistant' and c.text is string and ('{"tool_calls"' in c.text or '<tool_call>' in c.text) -%}
                {# skip leaked raw tool-call text fragments #}
            {%- elif role == 'user' -%}
                {{ clean_user_text(c.text) }}
            {%- elif role == 'assistant' -%}
                {{ c.text | replace('<system>', '') | replace('</system>', '') }}
            {%- else -%}
                {{ c.text }}
            {%- endif -%}
        {%- elif c.type is defined and c.type == 'image_url' -%}
            [image omitted]
        {%- elif c.text is defined -%}
            {%- if role == 'assistant' and c.text is string and ('{"tool_calls"' in c.text or '<tool_call>' in c.text) -%}
                {# skip leaked raw tool-call text fragments #}
            {%- elif role == 'user' -%}
                {{ clean_user_text(c.text) }}
            {%- elif role == 'assistant' -%}
                {{ c.text | replace('<system>', '') | replace('</system>', '') }}
            {%- else -%}
                {{ c.text }}
            {%- endif -%}
        {%- else -%}
            {{ c | tojson }}
        {%- endif -%}
    {%- elif c is sequence -%}
        {%- for part in c -%}
            {%- if part is mapping -%}
                {%- if part.type is defined and (part.type == 'thinking' or part.type == 'reasoning' or part.type == 'reasoning_content') -%}
                    {# skip reasoning blocks from history #}
                {%- elif part.thinking is defined -%}
                    {# skip reasoning blocks from history #}
                {%- elif part.type is defined and (part.type == 'text' or part.type == 'input_text') and part.text is defined -%}
                    {%- if role == 'assistant' and part.text is string and ('{"tool_calls"' in part.text or '<tool_call>' in part.text) -%}
                        {# skip leaked raw tool-call text fragments #}
                    {%- elif role == 'user' -%}
                        {{ clean_user_text(part.text) }}
                    {%- elif role == 'assistant' -%}
                        {{ part.text | replace('<system>', '') | replace('</system>', '') }}
                    {%- else -%}
                        {{ part.text }}
                    {%- endif -%}
                {%- elif part.type is defined and part.type == 'image_url' -%}
                    [image omitted]
                {%- elif part.text is defined -%}
                    {%- if role == 'assistant' and part.text is string and ('{"tool_calls"' in part.text or '<tool_call>' in part.text) -%}
                        {# skip leaked raw tool-call text fragments #}
                    {%- elif role == 'user' -%}
                        {{ clean_user_text(part.text) }}
                    {%- elif role == 'assistant' -%}
                        {{ part.text | replace('<system>', '') | replace('</system>', '') }}
                    {%- else -%}
                        {{ part.text }}
                    {%- endif -%}
                {%- else -%}
                    {{ part | tojson }}
                {%- endif -%}
            {%- elif part is string -%}
                {%- if role == 'assistant' and part is string and ('{"tool_calls"' in part or '<tool_call>' in part) -%}
                    {# skip leaked raw tool-call text fragments #}
                {%- elif role == 'user' -%}
                    {{ clean_user_text(part) }}
                {%- elif role == 'assistant' -%}
                    {{ part | replace('<system>', '') | replace('</system>', '') }}
                {%- else -%}
                    {{ part }}
                {%- endif -%}
            {%- else -%}
                {{ part | tojson }}
            {%- endif -%}
            {%- if not loop.last %}
 
            {%- endif -%}
        {%- endfor -%}
    {%- else -%}
        {{ c | tojson }}
    {%- endif -%}
{%- endmacro -%}

{%- if system_prompt -%}
    <|im_start|>system
    {{ system_prompt }}
    <|im_end|>
{%- endif -%}

{%- set ns_tool = namespace(total=0) -%}
{%- for mm in messages -%}
    {%- if mm.role == 'tool' -%}
        {%- set _tool_text = render_content(mm.content, 'tool') -%}
        {%- if not ('[[audio_as_voice]]' in _tool_text or 'MEDIA:/tmp/openclaw/tts-' in _tool_text) -%}
            {%- set ns_tool.total = ns_tool.total + 1 -%}
        {%- endif -%}
    {%- endif -%}
{%- endfor -%}

{%- set ns_last = namespace(user_text='') -%}
{%- for mm in messages -%}
    {%- if mm.role == 'user' and mm.content is not none -%}
        {%- set ns_last.user_text = render_content(mm.content, 'user') | lower -%}
    {%- endif -%}
{%- endfor -%}
{# force_web_search injection removed to avoid model parroting system status text #}

{%- if tools and (tools | length) > 0 -%}
<|im_start|>system
Make tool calls when needed.
Available tools:
    {%- for t in tools %}
        {%- set fn = t.function if t.function is defined else t %}
        - {{ fn.name }}
    {%- endfor %}

Tool policy:
- Do not repeat the same tool call with identical arguments.
- After a useful tool result, answer directly unless the user asked for another action.
- After one tool failure, do not blind-retry; ask one clarifying question.
- If a tool result contains `CRITICAL:` loop/circuit-breaker text, stop tool calls and answer briefly.
- Do not call `tts` unless explicitly asked for voice/audio.
- Final output: normal assistant text only.
- Do not emit pseudo-tags (`<system>`, `</system>`) or execution preambles (e.g., "Executing web_search...").
- Include `Reasoning:` only if the user explicitly requests reasoning.
- For web-search answers, provide concise bullets with source links.
When not calling tools:
- Give a direct assistant answer in normal text.
- If the last tool was `web_search`, include concise bullets with links from the returned results.
<|im_end|>
{%- endif -%}

{%- set ns_seen = namespace(tool=0) -%}
{%- for m in messages -%}
    {%- if m.role == 'assistant' and m.tool_calls -%}
        {%- set ns = namespace(has_non_tts=false) -%}
        {%- for tc in m.tool_calls -%}
            {%- set fn = tc.function if tc.function is defined else tc -%}
            {%- if fn.name != 'tts' -%}
                {%- set ns.has_non_tts = true -%}
            {%- endif -%}
        {%- endfor -%}
        {%- if m.content or (INCLUDE_TOOL_CALL_HISTORY and ns.has_non_tts) -%}
            <|im_start|>assistant
            {%- if m.content %}
                {{ render_content(m.content, 'assistant') }}
            {%- endif -%}
            {%- if INCLUDE_TOOL_CALL_HISTORY -%}
                {%- for tc in m.tool_calls -%}
                    {%- set fn = tc.function if tc.function is defined else tc -%}
                    {%- if fn.name != 'tts' -%}
                        <tool_call>
                        {"name":"{{ fn.name }}","arguments":{% if fn.arguments is string %}{{ fn.arguments }}{% else %}{{ fn.arguments | tojson }}{% endif %}}
                        </tool_call>
                    {%- endif -%}
                {%- endfor -%}
            {%- endif -%}
            <|im_end|>
        {%- endif -%}
    {%- elif m.role == 'tool' -%}
        {%- set tool_text = render_content(m.content, 'tool') -%}
        {%- if not ('[[audio_as_voice]]' in tool_text or 'MEDIA:/tmp/openclaw/tts-' in tool_text) -%}
            {%- set ns_seen.tool = ns_seen.tool + 1 -%}
            {%- if ns_seen.tool > (ns_tool.total - TOOL_HISTORY_LIMIT) -%}
                <|im_start|>tool
                {{ tool_text[:TOOL_CONTENT_MAX] }}
                {%- if tool_text|length > TOOL_CONTENT_MAX %}
                [tool content truncated for context safety]
                {%- endif %}
                <|im_end|>
            {%- endif -%}
        {%- endif -%}
    {%- else -%}
        {%- if m.content is not none -%}
            <|im_start|>{{ m.role }}
            {{ render_content(m.content, m.role) }}
            <|im_end|>
        {%- endif -%}
    {%- endif -%}
{%- endfor -%}

{%- if add_generation_prompt | default(true) -%}
    <|im_start|>assistant
{%- endif -%}
