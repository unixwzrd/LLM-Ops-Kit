{{- bos_token -}}
{%- set TOOL_CONTENT_MAX = 12000 -%}
{%- set TOOL_HISTORY_LIMIT = 1 -%}
{%- set INCLUDE_TOOL_CALL_HISTORY = false -%}

{%- macro strip_think_blocks(text) -%}
    {%- if text is not string -%}
        {{ text }}
    {%- elif '<think>' in text and '</think>' in text -%}
        {{ text.split('</think>')[-1].lstrip('\n') }}
    {%- else -%}
        {{ text }}
    {%- endif -%}
{%- endmacro -%}

{%- macro clean_user_text(t) -%}
    {%- if t is string and 'Conversation info (untrusted metadata):' in t -%}
        {%- set parts = t.split('\n\n') -%}
        {%- if parts|length >= 2 -%}
            {{ parts[-1] }}
        {%- else -%}
            {{ t }}
        {%- endif -%}
    {%- else -%}
        {{ t }}
    {%- endif -%}
{%- endmacro -%}

{%- macro render_content(c, role='') -%}
    {%- if c is string -%}
        {%- if role == 'assistant' and ('{"tool_calls"' in c or '<tool_call>' in c) -%}
        {%- elif role == 'user' -%}
            {{ clean_user_text(c) }}
        {%- elif role == 'assistant' -%}
            {{ strip_think_blocks(c) | replace('<system>', '') | replace('</system>', '') }}
        {%- else -%}
            {{ c }}
        {%- endif -%}
    {%- elif c is mapping -%}
        {%- if c.type is defined and (c.type == 'thinking' or c.type == 'reasoning' or c.type == 'reasoning_content') -%}
        {%- elif c.thinking is defined -%}
        {%- elif c.type is defined and (c.type == 'text' or c.type == 'input_text') and c.text is defined -%}
            {%- if role == 'assistant' and c.text is string and ('{"tool_calls"' in c.text or '<tool_call>' in c.text) -%}
            {%- elif role == 'user' -%}
                {{ clean_user_text(c.text) }}
            {%- elif role == 'assistant' -%}
                {{ strip_think_blocks(c.text) | replace('<system>', '') | replace('</system>', '') }}
            {%- else -%}
                {{ c.text }}
            {%- endif -%}
        {%- elif c.type is defined and c.type == 'image_url' -%}
            [image omitted]
        {%- elif c.text is defined -%}
            {%- if role == 'assistant' and c.text is string and ('{"tool_calls"' in c.text or '<tool_call>' in c.text) -%}
            {%- elif role == 'user' -%}
                {{ clean_user_text(c.text) }}
            {%- elif role == 'assistant' -%}
                {{ strip_think_blocks(c.text) | replace('<system>', '') | replace('</system>', '') }}
            {%- else -%}
                {{ c.text }}
            {%- endif -%}
        {%- else -%}
            {{ c | tojson }}
        {%- endif -%}
    {%- elif c is sequence -%}
        {%- for part in c -%}
            {%- if part is mapping -%}
                {%- if part.type is defined and (part.type == 'thinking' or part.type == 'reasoning' or part.type == 'reasoning_content') -%}
                {%- elif part.thinking is defined -%}
                {%- elif part.type is defined and (part.type == 'text' or part.type == 'input_text') and part.text is defined -%}
                    {%- if role == 'assistant' and part.text is string and ('{"tool_calls"' in part.text or '<tool_call>' in part.text) -%}
                    {%- elif role == 'user' -%}
                        {{ clean_user_text(part.text) }}
                    {%- elif role == 'assistant' -%}
                        {{ strip_think_blocks(part.text) | replace('<system>', '') | replace('</system>', '') }}
                    {%- else -%}
                        {{ part.text }}
                    {%- endif -%}
                {%- elif part.type is defined and part.type == 'image_url' -%}
                    [image omitted]
                {%- elif part.text is defined -%}
                    {%- if role == 'assistant' and part.text is string and ('{"tool_calls"' in part.text or '<tool_call>' in part.text) -%}
                    {%- elif role == 'user' -%}
                        {{ clean_user_text(part.text) }}
                    {%- elif role == 'assistant' -%}
                        {{ strip_think_blocks(part.text) | replace('<system>', '') | replace('</system>', '') }}
                    {%- else -%}
                        {{ part.text }}
                    {%- endif -%}
                {%- else -%}
                    {{ part | tojson }}
                {%- endif -%}
            {%- elif part is string -%}
                {%- if role == 'assistant' and ('{"tool_calls"' in part or '<tool_call>' in part) -%}
                {%- elif role == 'user' -%}
                    {{ clean_user_text(part) }}
                {%- elif role == 'assistant' -%}
                    {{ strip_think_blocks(part) | replace('<system>', '') | replace('</system>', '') }}
                {%- else -%}
                    {{ part }}
                {%- endif -%}
            {%- else -%}
                {{ part | tojson }}
            {%- endif -%}
            {%- if not loop.last %}
 
            {%- endif -%}
        {%- endfor -%}
    {%- else -%}
        {{ c | tojson }}
    {%- endif -%}
{%- endmacro -%}

{%- if system_prompt -%}
<|im_start|>system
{{ system_prompt }}
<|im_end|>
{%- endif -%}

{%- set ns_last = namespace(user_text='') -%}
{%- for mm in messages -%}
    {%- if mm.role == 'user' and mm.content is not none -%}
        {%- set ns_last.user_text = render_content(mm.content, 'user') | lower -%}
    {%- endif -%}
{%- endfor -%}

{%- for m in messages -%}
    {%- if m.role == 'assistant' and m.tool_calls -%}
        {%- if m.content -%}
<|im_start|>assistant
{{ render_content(m.content, 'assistant') }}
<|im_end|>
        {%- endif -%}
    {%- elif m.role == 'tool' -%}
        {# Intentionally omit tool-result turns in the no-tools variant. #}
    {%- else -%}
        {%- if m.content is not none -%}
<|im_start|>{{ m.role }}
{{ render_content(m.content, m.role) }}
<|im_end|>
        {%- endif -%}
    {%- endif -%}
{%- endfor -%}

{%- if add_generation_prompt | default(true) -%}
<|im_start|>assistant
{%- endif -%}
