#!/usr/bin/env bash
set -euo pipefail

SOURCE="${BASH_SOURCE[0]}"
while [[ -h "$SOURCE" ]]; do
  DIR="$(cd -P "$(dirname "$SOURCE")" >/dev/null 2>&1 && pwd)"
  SOURCE="$(readlink "$SOURCE")"
  [[ "$SOURCE" != /* ]] && SOURCE="$DIR/$SOURCE"
done
SCRIPT_DIR="$(cd -P "$(dirname "$SOURCE")" >/dev/null 2>&1 && pwd)"
# shellcheck disable=SC1091
. "$SCRIPT_DIR/lib/common.sh"

action="${1:-status}"

openclaw_app_log_path() {
  local latest
  latest="$(ls -1t /tmp/openclaw/openclaw-*.log 2>/dev/null | head -n 1 || true)"
  if [[ -n "$latest" ]]; then
    printf '%s\n' "$latest"
  else
    printf '/tmp/openclaw/openclaw-%s.log\n' "$(date +%F)"
  fi
}

follow_gateway_logs() {
  local app_log
  app_log="$(openclaw_app_log_path)"
  ensure_runtime_dirs
  mkdir -p /tmp/openclaw
  prepare_log_file "$LLMOPS_LOG_DIR/gateway.log"
  prepare_log_file "$LLMOPS_LOG_DIR/gateway.err.log"
  touch "$app_log"
  echo "gateway: following logs"
  echo "  wrapper_log=$LLMOPS_LOG_DIR/gateway.log"
  echo "  wrapper_err=$LLMOPS_LOG_DIR/gateway.err.log"
  echo "  app_log=$app_log"
  tail -n 50 -F \
    "$LLMOPS_LOG_DIR/gateway.log" \
    "$LLMOPS_LOG_DIR/gateway.err.log" \
    "$app_log"
}

start_gateway() {
  load_shell_env
  ensure_runtime_dirs
  PORT="${LLMOPS_GATEWAY_PORT:-18789}"
  LOG_OUT="$LLMOPS_LOG_DIR/gateway.log"
  LOG_ERR="$LLMOPS_LOG_DIR/gateway.err.log"
  prune_runtime_artifacts
  prepare_log_file "$LOG_OUT"
  prepare_log_file "$LOG_ERR"

  if pid="$(read_pid gateway 2>/dev/null)" && is_pid_running "$pid"; then
    echo "gateway: already running pid=$pid"
    return 0
  fi

  nohup /usr/local/bin/openclaw gateway run --port "$PORT" > "$LOG_OUT" 2> "$LOG_ERR" &
  pid="$!"
  write_pid gateway "$pid"

  # Verify the process survived startup so we do not report false success.
  sleep 1
  if ! is_pid_running "$pid"; then
    rm -f "$(pid_file_for gateway)"
    echo "gateway: failed to start (process exited)" >&2
    echo "gateway: inspect $LOG_OUT and $LOG_ERR" >&2
    return 1
  fi

  if command -v curl >/dev/null 2>&1; then
    if ! curl -fsS "http://127.0.0.1:${PORT}/health" >/dev/null 2>&1; then
      echo "gateway: started pid=$pid port=$PORT (health endpoint not ready yet)"
      echo "gateway: wrapper logs -> $LOG_OUT / $LOG_ERR"
      echo "gateway: app log -> $(openclaw_app_log_path)"
      return 0
    fi
  fi

  echo "gateway: started pid=$pid port=$PORT"
  echo "gateway: wrapper logs -> $LOG_OUT / $LOG_ERR"
  echo "gateway: app log -> $(openclaw_app_log_path)"
}

stop_gateway() {
  stop_by_name gateway
}

status_gateway() {
  local port
  port="${LLMOPS_GATEWAY_PORT:-18789}"
  if pid="$(read_pid gateway 2>/dev/null)"; then
    if is_pid_running "$pid"; then
      echo "gateway: running pid=$pid"
      echo "  port=$port"
      echo "  mode=direct-run wrapper"
      echo "  log=$LLMOPS_LOG_DIR/gateway.log"
      echo "  err_log=$LLMOPS_LOG_DIR/gateway.err.log"
      echo "  app_log=$(openclaw_app_log_path)"
      echo "  runtime_mode=$(runtime_mode)"
      echo "  runtime_root=$(runtime_asset_root)"
      echo "  retention=$(retention_summary_line)"
      echo "  note=openclaw logs --follow may fail in this mode; use wrapper/app logs directly"
      return 0
    fi
    echo "gateway: stale pid=$pid"
    echo "  port=$port"
    echo "  mode=direct-run wrapper"
    echo "  log=$LLMOPS_LOG_DIR/gateway.log"
    echo "  err_log=$LLMOPS_LOG_DIR/gateway.err.log"
    echo "  app_log=$(openclaw_app_log_path)"
    echo "  runtime_mode=$(runtime_mode)"
    echo "  runtime_root=$(runtime_asset_root)"
    echo "  retention=$(retention_summary_line)"
    return 1
  fi
  echo "gateway: stopped"
  echo "  port=$port"
  echo "  mode=direct-run wrapper"
  echo "  log=$LLMOPS_LOG_DIR/gateway.log"
  echo "  err_log=$LLMOPS_LOG_DIR/gateway.err.log"
  echo "  app_log=$(openclaw_app_log_path)"
  echo "  runtime_mode=$(runtime_mode)"
  echo "  runtime_root=$(runtime_asset_root)"
  echo "  retention=$(retention_summary_line)"
  return 1
}

case "$action" in
  start) start_gateway ;;
  stop) stop_gateway ;;
  restart) stop_gateway || true; start_gateway ;;
  status) status_gateway ;;
  logs) follow_gateway_logs ;;
  *) echo "Usage: gateway [start|stop|restart|status|logs]" >&2; exit 2 ;;
esac
