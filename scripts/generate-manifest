#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"
MANIFEST_FILE="${MANIFEST_FILE:-$SCRIPT_DIR/runtime-links.manifest}"

# Static runtime commands that are not modelctl launchers.
STATIC_ENTRIES=(
  "gateway|scripts/gateway"
  "proxy|scripts/proxy"
  "openclaw-stack|scripts/openclaw-stack"
  "openclaw-report|scripts/openclaw-report.sh"
  "sync-agent-work|scripts/sync-agent-work.sh"
  "openai-proxy-tap|bin/openai-proxy-tap"
  "node-hygiene|bin/node-hygiene.sh"
)

launcher_names=()
while IFS= read -r path; do
  name="$(basename "$path")"
  target="$(readlink "$path")"
  # include launchers symlinked to modelctl (relative or absolute)
  if [[ "$target" == "modelctl" || "$target" == "$SCRIPT_DIR/modelctl" || "$target" == */modelctl ]]; then
    launcher_names+=("$name")
  fi
done < <(find "$SCRIPT_DIR" -maxdepth 1 -type l | sort)

if ((${#launcher_names[@]} > 0)); then
  mapfile -t launcher_names < <(printf '%s\n' "${launcher_names[@]}" | sort -u)
fi

{
  echo "# Runtime link manifest (target|source relative to BIN_DIR and REPO_DIR)"
  echo "# Auto-generated by scripts/generate-manifest"
  echo

  for entry in "${STATIC_ENTRIES[@]}"; do
    echo "$entry"
  done

  for name in "${launcher_names[@]}"; do
    echo "$name|scripts/$name"
  done
} > "$MANIFEST_FILE"

echo "WROTE: $MANIFEST_FILE"
