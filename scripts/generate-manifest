#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
BIN_SRC_DIR="$SCRIPT_DIR/../bin"
MANIFEST_FILE="${MANIFEST_FILE:-$SCRIPT_DIR/runtime-links.manifest}"

is_excluded_script() {
  local name="$1"
  case "$name" in
    modelctl|generate-manifest|deploy-runtime-links.sh|verify-runtime-links.sh|setup-ssh-deploy-key.sh|post-commit-sync.sample|sanitized-daily-report.sh|jinja-snapshot.sh|node-hygiene.sh|model_proxy_tap.py|render_chatml_prompt.py)
      return 0
      ;;
    *.py|*.sample)
      return 0
      ;;
    *)
      return 1
      ;;
  esac
}

is_excluded_bin() {
  local name="$1"
  case "$name" in
    openclaw-start.sh|node-hygiene.sh)
      return 0
      ;;
    *)
      return 1
      ;;
  esac
}

profile_names=()
while IFS= read -r model_file; do
  base="$(basename "$model_file")"
  profile_names+=("${base%.sh}")
done < <(find "$SCRIPT_DIR/models" -maxdepth 1 -type f -name '*.sh' | sort)

# Ensure TTS wrapper exists when TTS model profile exists.
if [[ -f "$SCRIPT_DIR/models/Qwen3TTS.sh" && ! -f "$SCRIPT_DIR/tts" ]]; then
  cat > "$SCRIPT_DIR/tts" <<'EOF'
#!/usr/bin/env bash
set -euo pipefail
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
exec "$SCRIPT_DIR/modelctl" Qwen3TTS "${@:-start}"
EOF
  chmod +x "$SCRIPT_DIR/tts"
  echo "CREATED_TTS_WRAPPER: $SCRIPT_DIR/tts"
fi

# Ensure each model profile has a launcher symlink in scripts/.
for name in "${profile_names[@]}"; do
  launcher="$SCRIPT_DIR/$name"
  if [[ ! -e "$launcher" ]]; then
    ln -s modelctl "$launcher"
    echo "CREATED_LAUNCHER: $launcher -> modelctl"
    continue
  fi

  if [[ -L "$launcher" ]]; then
    target="$(readlink "$launcher")"
    if [[ "$target" != "modelctl" && "$target" != "$SCRIPT_DIR/modelctl" && "$target" != */modelctl ]]; then
      echo "SKIP_NON_MODELCTL_LAUNCHER: $launcher -> $target" >&2
    fi
  fi
done

# Remove stale launcher symlinks pointing to modelctl with no matching model profile.
while IFS= read -r path; do
  name="$(basename "$path")"
  target="$(readlink "$path")"
  if [[ "$target" != "modelctl" && "$target" != "$SCRIPT_DIR/modelctl" && "$target" != */modelctl ]]; then
    continue
  fi
  if [[ ! -f "$SCRIPT_DIR/models/$name.sh" ]]; then
    rm -f "$path"
    echo "REMOVED_STALE_LAUNCHER: $path"
  fi
done < <(find "$SCRIPT_DIR" -maxdepth 1 -type l | sort)

launcher_names=()
while IFS= read -r path; do
  name="$(basename "$path")"
  target="$(readlink "$path")"
  # include launchers symlinked to modelctl (relative or absolute)
  if [[ "$target" == "modelctl" || "$target" == "$SCRIPT_DIR/modelctl" || "$target" == */modelctl ]]; then
    launcher_names+=("$name")
  fi
done < <(find "$SCRIPT_DIR" -maxdepth 1 -type l | sort)

if ((${#launcher_names[@]} > 0)); then
  unique_launchers=()
  while IFS= read -r name; do
    unique_launchers+=("$name")
  done < <(printf '%s\n' "${launcher_names[@]}" | sort -u)
  launcher_names=("${unique_launchers[@]}")
fi

runtime_entries=()

# Auto-discover executable runtime scripts from scripts/.
while IFS= read -r path; do
  name="$(basename "$path")"
  if is_excluded_script "$name"; then
    continue
  fi
  target="$name"
  if [[ "$target" == *.sh ]]; then
    target="${target%.sh}"
  fi
  runtime_entries+=("$target|scripts/$name")
done < <(find "$SCRIPT_DIR" -maxdepth 1 \( -type f -o -type l \) -perm -u+x | sort)

# Ensure modelctl itself is always available in ~/bin.
runtime_entries+=("modelctl|scripts/modelctl")

# Auto-discover executable runtime scripts from bin/.
if [[ -d "$BIN_SRC_DIR" ]]; then
  while IFS= read -r path; do
    name="$(basename "$path")"
    if is_excluded_bin "$name"; then
      continue
    fi
    target="$name"
    if [[ "$target" == *.sh ]]; then
      target="${target%.sh}"
    fi
    runtime_entries+=("$target|bin/$name")
  done < <(find "$BIN_SRC_DIR" -maxdepth 1 \( -type f -o -type l \) -perm -u+x | sort)
fi

{
  echo "# Runtime link manifest (target|source relative to BIN_DIR and REPO_DIR)"
  echo "# Auto-generated by scripts/generate-manifest"
  echo

  if ((${#runtime_entries[@]} > 0)); then
    while IFS= read -r entry; do
      [[ -n "$entry" ]] && echo "$entry"
    done < <(printf '%s\n' "${runtime_entries[@]}" | sort -u)
  fi

  for name in "${launcher_names[@]}"; do
    echo "$name|scripts/$name"
  done
} > "$MANIFEST_FILE"

# De-duplicate final manifest and keep comments/header.
tmp_manifest="$(mktemp)"
{
  head -n 3 "$MANIFEST_FILE"
  tail -n +4 "$MANIFEST_FILE" | sed '/^$/d' | sort -u
} > "$tmp_manifest"
mv "$tmp_manifest" "$MANIFEST_FILE"

echo "WROTE: $MANIFEST_FILE"
