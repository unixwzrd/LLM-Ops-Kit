# OpenClaw backend defaults for agentctl.
# Copy to ~/.llm-ops/config/agents/openclaw.env to customize locally.

OPENCLAW_HOME="${OPENCLAW_HOME:-$HOME/.openclaw}"
OPENCLAW_GATEWAY_CMD="${OPENCLAW_GATEWAY_CMD:-/usr/local/bin/openclaw}"
LLMOPS_GATEWAY_PORT="${LLMOPS_GATEWAY_PORT:-18789}"
LLMOPS_AGENT_NATIVE_ENV_FILE="${LLMOPS_AGENT_NATIVE_ENV_FILE:-$OPENCLAW_HOME/.env}"
LLMOPS_AGENT_SECKIT_NAMES="${LLMOPS_AGENT_SECKIT_NAMES:-OPENCLAW_GATEWAY_TOKEN,TELEGRAM_BOT_TOKEN}"
