# Hermes backend defaults for agentctl.
# Copy to ~/.llm-ops/config/agents/hermes.env to customize locally.

HERMES_HOME="${HERMES_HOME:-$HOME/.hermes}"
HERMES_GATEWAY_CMD="${HERMES_GATEWAY_CMD:-hermes}"
LLMOPS_AGENT_SHELL_INIT_FILE="${LLMOPS_AGENT_SHELL_INIT_FILE:-$HOME/.bashrc}"
LLMOPS_AGENT_NATIVE_ENV_FILE="${LLMOPS_AGENT_NATIVE_ENV_FILE:-$HERMES_HOME/.env}"
LLMOPS_AGENT_SECKIT_NAMES="${LLMOPS_AGENT_SECKIT_NAMES:-TELEGRAM_BOT_TOKEN,VOICE_TOOLS_OPENAI_KEY}"
HERMES_GATEWAY_ARGS="${HERMES_GATEWAY_ARGS:---replace}"
