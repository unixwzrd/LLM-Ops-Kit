#!/usr/bin/env bash
set -euo pipefail

SOURCE="${BASH_SOURCE[0]}"
while [[ -h "$SOURCE" ]]; do
  DIR="$(cd -P "$(dirname "$SOURCE")" >/dev/null 2>&1 && pwd)"
  SOURCE="$(readlink "$SOURCE")"
  [[ "$SOURCE" != /* ]] && SOURCE="$DIR/$SOURCE"
done
SCRIPT_DIR="$(cd -P "$(dirname "$SOURCE")" >/dev/null 2>&1 && pwd)"
# shellcheck disable=SC1091
. "$SCRIPT_DIR/lib/common.sh"

action="${1:-status}"
target="${2:-all}"

start_target() {
  case "$1" in
    gateway) "$SCRIPT_DIR/gateway" start ;;
    llm) "$SCRIPT_DIR/Qwen3" start ;;
    embedding) "$SCRIPT_DIR/BGEen" start ;;
    tts) "$SCRIPT_DIR/Qwen3TTS" start ;;
    model-proxy) "$SCRIPT_DIR/model-proxy" start ;;
    models)
      "$SCRIPT_DIR/Qwen3" start & p1=$!
      "$SCRIPT_DIR/BGEen" start & p2=$!
      wait "$p1" "$p2"
      ;;
    all)
      "$SCRIPT_DIR/gateway" start
      "$SCRIPT_DIR/model-proxy" start
      "$SCRIPT_DIR/Qwen3" start & p1=$!
      "$SCRIPT_DIR/BGEen" start & p2=$!
      wait "$p1" "$p2"
      ;;
    *) echo "Unknown start target: $1" >&2; exit 2 ;;
  esac
}

stop_target() {
  case "$1" in
    gateway) "$SCRIPT_DIR/gateway" stop || true ;;
    llm) "$SCRIPT_DIR/Qwen3" stop || true ;;
    embedding) "$SCRIPT_DIR/BGEen" stop || true ;;
    tts) "$SCRIPT_DIR/Qwen3TTS" stop || true ;;
    model-proxy) "$SCRIPT_DIR/model-proxy" stop || true ;;
    models)
      "$SCRIPT_DIR/BGEen" stop || true
      "$SCRIPT_DIR/Qwen3" stop || true
      ;;
    all)
      "$SCRIPT_DIR/model-proxy" stop || true
      "$SCRIPT_DIR/Qwen3TTS" stop || true
      "$SCRIPT_DIR/BGEen" stop || true
      "$SCRIPT_DIR/Qwen3" stop || true
      "$SCRIPT_DIR/gateway" stop || true
      ;;
    *) echo "Unknown stop target: $1" >&2; exit 2 ;;
  esac
}

status_all() {
  ensure_runtime_dirs
  for name in gateway llama-Qwen3VL llama-bge-small-en tts-Qwen3TTS model-proxy; do
    if pid="$(read_pid "$name" 2>/dev/null)"; then
      if is_pid_running "$pid"; then
        echo "$name: running pid=$pid"
      else
        echo "$name: stale pid=$pid"
      fi
    else
      echo "$name: stopped"
    fi
  done
}

case "$action" in
  start) start_target "$target" ;;
  stop) stop_target "$target" ;;
  restart) stop_target "$target"; start_target "$target" ;;
  status) status_all ;;
  *)
    echo "Usage: $0 {start|stop|restart|status} [all|gateway|llm|embedding|tts|model-proxy|models]" >&2
    exit 2
    ;;
esac
