#!/usr/bin/env bash
set -euo pipefail

SOURCE="${BASH_SOURCE[0]}"
while [[ -h "$SOURCE" ]]; do
  DIR="$(cd -P "$(dirname "$SOURCE")" >/dev/null 2>&1 && pwd)"
  SOURCE="$(readlink "$SOURCE")"
  [[ "$SOURCE" != /* ]] && SOURCE="$DIR/$SOURCE"
done
SCRIPT_DIR="$(cd -P "$(dirname "$SOURCE")" >/dev/null 2>&1 && pwd)"
# shellcheck disable=SC1091
. "$SCRIPT_DIR/lib/common.sh"

action="${1:-status}"
LLMOPS_REQUIRED_SECRETS="${LLMOPS_REQUIRED_SECRETS:-OPENCLAW_GATEWAY_TOKEN TELEGRAM_BOT_TOKEN OPENAI_API_KEY OPENROUTER_API_KEY ANTHROPIC_API_KEY GH_TOKEN BRAVE_SEARCH_API_KEY ELEVENLABS_API_KEY VOICE_TOOLS_OPENAI_KEY}"
requested_target="${2:-${LLMOPS_GATEWAY_BACKEND:-openclaw}}"

openclaw_app_log_path() {
  local latest
  latest="$(
    find /tmp/openclaw -maxdepth 1 -type f -name 'openclaw-*.log' -print0 2>/dev/null \
      | xargs -0 -I{} stat -f '%m %N' "{}" 2>/dev/null \
      | sort -nr \
      | head -n 1 \
      | cut -d' ' -f2- || true
  )"
  if [[ -n "$latest" ]]; then
    printf '%s\n' "$latest"
  else
    printf '/tmp/openclaw/openclaw-%s.log\n' "$(date +%F)"
  fi
}

hermes_home() {
  printf '%s\n' "${HERMES_HOME:-$HOME/.hermes}"
}

hermes_gateway_native_log_path() {
  printf '%s/logs/gateway.log\n' "$(hermes_home)"
}

hermes_gateway_native_error_log_path() {
  printf '%s/logs/gateway.error.log\n' "$(hermes_home)"
}

hermes_gateway_state_path() {
  printf '%s/gateway_state.json\n' "$(hermes_home)"
}

normalize_target() {
  local target="$1"
  case "$target" in
    ""|default)
      printf '%s\n' "${LLMOPS_GATEWAY_BACKEND:-openclaw}"
      ;;
    openclaw|hermes|all)
      printf '%s\n' "$target"
      ;;
    *)
      echo "agentctl: unsupported target '$target' (expected openclaw, hermes, or all)" >&2
      return 2
      ;;
  esac
}

backend_list_for_target() {
  local target="$1"
  case "$target" in
    all)
      printf 'openclaw\nhermes\n'
      ;;
    openclaw|hermes)
      printf '%s\n' "$target"
      ;;
    *)
      return 2
      ;;
  esac
}

agent_config_dir() {
  printf '%s/agents\n' "$LLMOPS_CONFIG_DIR"
}

agent_profile_path() {
  local backend="$1"
  printf '%s/agents/%s.env\n' "$SCRIPT_DIR" "$backend"
}

agent_override_path() {
  local backend="$1"
  printf '%s/%s.env\n' "$(agent_config_dir)" "$backend"
}

agent_legacy_override_path() {
  local backend="$1"
  printf '%s/%s.sh\n' "$(agent_config_dir)" "$backend"
}

ensure_agent_override_template() {
  local backend="$1"
  local profile_file override_file legacy_file
  profile_file="$(agent_profile_path "$backend")"
  override_file="$(agent_override_path "$backend")"
  legacy_file="$(agent_legacy_override_path "$backend")"

  [[ -f "$profile_file" ]] || return 0
  if [[ -f "$override_file" || -f "$legacy_file" ]]; then
    return 0
  fi

  mkdir -p "$(agent_config_dir)"
  cp "$profile_file" "$override_file"
  {
    echo "agentctl: no per-backend override file found for '$backend'"
    echo "agentctl: copied template config to $override_file"
    echo "agentctl: edit that file to customize launchd/runtime settings without touching the repo copy"
  } >&2
}

clear_agent_backend_vars() {
  unset LLMOPS_AGENT_NATIVE_ENV_FILE || true
  unset LLMOPS_AGENT_SECKIT_NAMES || true
}

load_agent_backend_config() {
  local backend="$1"
  local profile_file override_file legacy_file
  profile_file="$(agent_profile_path "$backend")"
  override_file="$(agent_override_path "$backend")"
  legacy_file="$(agent_legacy_override_path "$backend")"

  [[ -f "$profile_file" ]] || return 0
  clear_agent_backend_vars
  ensure_agent_override_template "$backend"

  if [[ -f "$override_file" ]]; then
    # shellcheck disable=SC1090
    . "$override_file"
  elif [[ -f "$legacy_file" ]]; then
    echo "agentctl: legacy per-backend override detected at $legacy_file" >&2
    echo "agentctl: prefer renaming it to $override_file" >&2
    # shellcheck disable=SC1090
    . "$legacy_file"
  fi

  # shellcheck disable=SC1090,SC1091
  . "$profile_file"
}

source_agent_native_env_file() {
  local env_file="${LLMOPS_AGENT_NATIVE_ENV_FILE:-}"
  [[ -n "$env_file" ]] || return 0
  [[ -f "$env_file" ]] || return 0
  set +u
  # shellcheck disable=SC1090
  . "$env_file"
  set -u
}

load_agent_backend_launchd_env() {
  local backend="$1"
  local previous_names="${LLMOPS_SECKIT_NAMES-}"
  local had_names=0

  load_agent_backend_config "$backend"
  source_agent_native_env_file

  if [[ -n "${LLMOPS_AGENT_SECKIT_NAMES:-}" ]]; then
    if [[ -n "${LLMOPS_SECKIT_NAMES+x}" ]]; then
      had_names=1
    fi
    export LLMOPS_SECKIT_NAMES="$LLMOPS_AGENT_SECKIT_NAMES"
    maybe_load_seckit_env
    maybe_warn_env_secret_fallback
    if [[ "$had_names" == "1" ]]; then
      export LLMOPS_SECKIT_NAMES="$previous_names"
    else
      unset LLMOPS_SECKIT_NAMES || true
    fi
  fi
}

gateway_pid_name() {
  local backend="$1"
  printf 'agentctl-%s\n' "$backend"
}

gateway_log_path() {
  local backend="$1"
  printf '%s/agentctl-%s.log\n' "$LLMOPS_LOG_DIR" "$backend"
}

gateway_err_log_path() {
  local backend="$1"
  printf '%s/agentctl-%s.err.log\n' "$LLMOPS_LOG_DIR" "$backend"
}

gateway_status_suffix() {
  local backend="$1"
  echo "  backend=$backend"
  echo "  mode=direct-run wrapper"
  echo "  backend_config=$(agent_override_path "$backend")"
  if [[ -n "${LLMOPS_AGENT_NATIVE_ENV_FILE:-}" ]]; then
    echo "  native_env=${LLMOPS_AGENT_NATIVE_ENV_FILE}"
  fi
  echo "  log=$(gateway_log_path "$backend")"
  echo "  err_log=$(gateway_err_log_path "$backend")"
  echo "  runtime_mode=$(runtime_mode)"
  echo "  runtime_root=$(runtime_asset_root)"
  echo "  retention=$(retention_summary_line)"
}

print_hermes_runtime_state() {
  local state_file="$1"
  [[ -f "$state_file" ]] || return 0
  if ! command -v jq >/dev/null 2>&1; then
    return 0
  fi
  jq -r '(
    [
      (.gateway_state // empty | "gateway_state=\(.)"),
      (.updated_at // empty | "updated_at=\(.)"),
      (.exit_reason // empty | "exit_reason=\(.)")
    ]
    + (
      (.platforms // {})
      | to_entries
      | map(
          "platform_" + .key + "=" + (.value.state // "unknown") +
          (if .value.error_code then " (" + .value.error_code + ")" else "" end)
        )
    )
  )[]' "$state_file"
}

start_gateway_backend() {
  local backend="$1"
  local pid port hermes_cmd openclaw_cmd pid_name
  load_agent_backend_config "$backend"
  port="${LLMOPS_GATEWAY_PORT:-18789}"
  pid_name="$(gateway_pid_name "$backend")"

  prepare_log_file "$(gateway_log_path "$backend")"
  prepare_log_file "$(gateway_err_log_path "$backend")"

  if pid="$(read_pid "$pid_name" 2>/dev/null)" && is_pid_running "$pid"; then
    echo "agentctl[$backend]: already running pid=$pid"
    return 0
  fi

  case "$backend" in
    openclaw)
      openclaw_cmd="${OPENCLAW_GATEWAY_CMD:-/usr/local/bin/openclaw}"
      if ! command -v "$openclaw_cmd" >/dev/null 2>&1; then
        echo "agentctl[$backend]: command not found: $openclaw_cmd" >&2
        return 1
      fi
      nohup "$openclaw_cmd" gateway run --port "$port" > "$(gateway_log_path "$backend")" 2> "$(gateway_err_log_path "$backend")" < /dev/null &
      ;;
    hermes)
      hermes_cmd="${HERMES_GATEWAY_CMD:-hermes}"
      if ! command -v "$hermes_cmd" >/dev/null 2>&1; then
        echo "agentctl[$backend]: command not found: $hermes_cmd" >&2
        return 1
      fi
      nohup "$hermes_cmd" gateway run > "$(gateway_log_path "$backend")" 2> "$(gateway_err_log_path "$backend")" < /dev/null &
      ;;
  esac

  pid="$!"
  write_pid "$pid_name" "$pid"
  start_log_marktime "$pid_name" "$pid_name" "$(gateway_log_path "$backend")"

  sleep 1
  if ! is_pid_running "$pid"; then
    stop_log_marktime "$pid_name"
    rm -f "$(pid_file_for "$pid_name")"
    echo "agentctl[$backend]: failed to start (process exited)" >&2
    echo "agentctl[$backend]: inspect $(gateway_log_path "$backend") and $(gateway_err_log_path "$backend")" >&2
    return 1
  fi

  echo "agentctl[$backend]: started pid=$pid"
  echo "  log=$(gateway_log_path "$backend")"
  echo "  err_log=$(gateway_err_log_path "$backend")"
  case "$backend" in
    openclaw)
      echo "  port=$port"
      echo "  app_log=$(openclaw_app_log_path)"
      ;;
    hermes)
      echo "  hermes_home=$(hermes_home)"
      echo "  native_log=$(hermes_gateway_native_log_path)"
      echo "  native_state=$(hermes_gateway_state_path)"
      ;;
  esac
}

stop_gateway_backend() {
  local backend="$1"
  local pid_name
  pid_name="$(gateway_pid_name "$backend")"
  stop_log_marktime "$pid_name"
  stop_by_name "$pid_name"
}

status_gateway_backend() {
  local backend="$1"
  local pid_name pid port state_file rc=1
  load_agent_backend_config "$backend"
  pid_name="$(gateway_pid_name "$backend")"
  port="${LLMOPS_GATEWAY_PORT:-18789}"
  state_file="$(hermes_gateway_state_path)"

  if pid="$(read_pid "$pid_name" 2>/dev/null)"; then
    if is_pid_running "$pid"; then
      echo "agentctl[$backend]: running pid=$pid"
      gateway_status_suffix "$backend"
      case "$backend" in
        openclaw)
          echo "  port=$port"
          echo "  app_log=$(openclaw_app_log_path)"
          echo "  note=openclaw logs --follow may fail in this mode; use wrapper/app logs directly"
          ;;
        hermes)
          echo "  hermes_home=$(hermes_home)"
          echo "  native_log=$(hermes_gateway_native_log_path)"
          echo "  native_err_log=$(hermes_gateway_native_error_log_path)"
          echo "  native_state=$state_file"
          while IFS= read -r line; do
            [[ -n "$line" ]] && echo "  $line"
          done < <(print_hermes_runtime_state "$state_file")
          echo "  note=Hermes config is owned by ~/.hermes/config.yaml, ~/.hermes/.env, and legacy ~/.hermes/gateway.json"
          ;;
      esac
      return 0
    fi
    echo "agentctl[$backend]: stale pid=$pid"
  else
    echo "agentctl[$backend]: stopped"
  fi

  gateway_status_suffix "$backend"
  case "$backend" in
    openclaw)
      echo "  port=$port"
      echo "  app_log=$(openclaw_app_log_path)"
      ;;
    hermes)
      echo "  hermes_home=$(hermes_home)"
      echo "  native_log=$(hermes_gateway_native_log_path)"
      echo "  native_err_log=$(hermes_gateway_native_error_log_path)"
      echo "  native_state=$state_file"
      while IFS= read -r line; do
        [[ -n "$line" ]] && echo "  $line"
      done < <(print_hermes_runtime_state "$state_file")
      ;;
  esac
  return 1
}

follow_gateway_logs_backend() {
  local backend="$1"
  case "$backend" in
    openclaw)
      mkdir -p /tmp/openclaw
      touch "$(openclaw_app_log_path)"
      printf '%s\n' \
        "$(gateway_log_path "$backend")" \
        "$(gateway_err_log_path "$backend")" \
        "$(openclaw_app_log_path)"
      ;;
    hermes)
      mkdir -p "$(hermes_home)/logs"
      touch "$(hermes_gateway_native_log_path)" "$(hermes_gateway_native_error_log_path)"
      printf '%s\n' \
        "$(gateway_log_path "$backend")" \
        "$(gateway_err_log_path "$backend")" \
        "$(hermes_gateway_native_log_path)" \
        "$(hermes_gateway_native_error_log_path)"
      ;;
  esac
}

start_gateway() {
  local target="$1"
  local backend rc=0
  load_shell_env
  ensure_runtime_dirs
  prune_runtime_artifacts
  while IFS= read -r backend; do
    [[ -n "$backend" ]] || continue
    start_gateway_backend "$backend" || rc=$?
  done < <(backend_list_for_target "$target")
  return "$rc"
}

stop_gateway() {
  local target="$1"
  local backend rc=0
  load_shell_env
  while IFS= read -r backend; do
    [[ -n "$backend" ]] || continue
    stop_gateway_backend "$backend" || rc=$?
  done < <(backend_list_for_target "$target")
  return "$rc"
}

status_gateway() {
  local target="$1"
  local backend rc=0
  load_shell_env
  while IFS= read -r backend; do
    [[ -n "$backend" ]] || continue
    status_gateway_backend "$backend" || rc=1
  done < <(backend_list_for_target "$target")
  return "$rc"
}

follow_gateway_logs() {
  local target="$1"
  local backend
  local -a files=()
  load_shell_env
  ensure_runtime_dirs
  while IFS= read -r backend; do
    [[ -n "$backend" ]] || continue
    prepare_log_file "$(gateway_log_path "$backend")"
    prepare_log_file "$(gateway_err_log_path "$backend")"
    while IFS= read -r path; do
      [[ -n "$path" ]] && files+=("$path")
    done < <(follow_gateway_logs_backend "$backend")
  done < <(backend_list_for_target "$target")

  echo "agentctl: following logs for target=$target"
  for path in "${files[@]}"; do
    echo "  $path"
  done
  tail -n 50 -F "${files[@]}"
}

launchd_run_gateway_backend() {
  local backend="$1"
  local port hermes_cmd openclaw_cmd

  if [[ "$backend" == "all" ]]; then
    echo "agentctl: launchd-run requires a concrete backend (openclaw or hermes)" >&2
    return 2
  fi

  LLMOPS_SKIP_SECKIT_LOAD=1 load_shell_env
  load_agent_backend_launchd_env "$backend"
  port="${LLMOPS_GATEWAY_PORT:-18789}"

  case "$backend" in
    openclaw)
      openclaw_cmd="${OPENCLAW_GATEWAY_CMD:-/usr/local/bin/openclaw}"
      exec "$openclaw_cmd" gateway run --port "$port"
      ;;
    hermes)
      hermes_cmd="${HERMES_GATEWAY_CMD:-hermes}"
      exec "$hermes_cmd" gateway run
      ;;
    *)
      echo "agentctl: unsupported launchd backend '$backend'" >&2
      return 2
      ;;
  esac
}

setup_gateway() {
  local target="$1"
  local hermes_cmd
  load_shell_env
  case "$target" in
    hermes)
      hermes_cmd="${HERMES_GATEWAY_CMD:-hermes}"
      exec "$hermes_cmd" gateway setup
      ;;
    all)
      echo "agentctl: setup only applies to hermes; running Hermes setup" >&2
      hermes_cmd="${HERMES_GATEWAY_CMD:-hermes}"
      exec "$hermes_cmd" gateway setup
      ;;
    openclaw)
      echo "agentctl: setup is only supported for the hermes backend" >&2
      return 2
      ;;
  esac
}

target="$(normalize_target "$requested_target")"

case "$action" in
  start) start_gateway "$target" ;;
  stop) stop_gateway "$target" ;;
  restart) stop_gateway "$target" || true; start_gateway "$target" ;;
  status) status_gateway "$target" ;;
  logs) follow_gateway_logs "$target" ;;
  setup) setup_gateway "$target" ;;
  launchd-run) launchd_run_gateway_backend "$target" ;;
  *) echo "Usage: agentctl [start|stop|restart|status|logs|setup|launchd-run] [openclaw|hermes|all]" >&2; exit 2 ;;
esac
